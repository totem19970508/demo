               <Image ID="copyedata"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="moveedata">
            <Macro>
               <Name>Move Entity Data</Name>
               <Command>^c^c_moveedata</Command>
               <HelpString>Moves Entity Data from one entity to another. (MOVEEDATA)</HelpString>
               <Image ID="moveedata"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="deledata">
            <Macro>
               <Name>Delete Entity Data</Name>
