               <Name>Section Plane to Block</Name>
               <Command>^c^c_sectionplanetoblock</Command>
               <HelpString>Opens the Create Section/Elevation dialog, to save section geometry as a block, or an external .dwg file. (SECTIONPLANETOBLOCK)</HelpString>
               <Image ID="sectionplanetoblock"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="livesection">
            <Macro>
               <Name>Livesection</Name>
               <Command>^c^c_livesection</Command>
               <HelpString>Toggles section views on/off. (LIVESECTION)</HelpString>
               <Image ID="livesection"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="clipdisplay">
            <Macro>
               <Name>Clip Display</Name>
               <Command>^c^c_clipdisplay</Command>
               <HelpString>Toggles the Clip Display property of section planes and BIM section entities on/off. (CLIPDISPLAY)</HelpString>
