      <MacroGroup Name="Welding Features">
         <MenuMacro UID="bmweldannotate">
            <Macro>
               <Name>Annotate Weld</Name>
               <Command>^c^c_bmweldannotate</Command>
               <HelpString>Places 2D weld representations of caterpillar seams and weld side-views on generated drawing views in Paper Space. (BMWELDANNOTATE)</HelpString>
               <Image ID="bm_weldannotate"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="fillet_weld">
            <Macro>
               <Name>Fillet Welding</Name>
               <Command>^c^c_bmwelding;</Command>
               <HelpString>Creates a 3D triangular body representation of a Fillet weld along intersection of selected faces.</HelpString>
               <Image ID="fillet_weld"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="groove_weld">
            <Macro>
               <Name>Groove Weld</Name>
               <Command>^c^c_bmwelding;_g;</Command>
               <HelpString>Creates a lofted 3D weld representation between selected sets of faces. Each selection set of faces should mirror the other selection set, in both selection order and amount of faces.</HelpString>
               <Image ID="groove_weld"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="amsimpleweld">
            <Macro>
               <Name>Simple Weld</Name>
               <Command>^c^c_amsimpleweld</Command>
               <HelpString>Draws seam and fillet welds on ellipses, circles, arcs, lines and polylines. (AMSIMPLEWELD)</HelpString>
               <Image ID="mcad_amsimpleweld"/>
            </Macro>
         </MenuMacro>
      </MacroGroup>
      <MacroGroup Name="Window">
         <MenuMacro UID="wiarrange">
            <Macro>
               <Name>Arrange</Name>
               <Command>'_wiarrange</Command>
               <HelpString>Arranges the icons of minimized windows at the bottom of the screen. (WIARRANGE)</HelpString>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="wclose">
            <Macro>
               <Name>Close</Name>
               <Command>^c^c_wclose</Command>
               <HelpString>Closes the current drawing window. (WCLOSE)</HelpString>
               <Image ID="erase"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="wcloseall">
            <Macro>
               <Name>Close All</Name>
               <Command>^c^c_wcloseall</Command>
               <HelpString>Closes all drawing windows. (WCLOSEALL)</HelpString>
               <Image ID="erase"/>
            </Macro>
         </MenuMacro>
         
         <MenuMacro UID="whtile">
