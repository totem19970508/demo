               <HelpString>Attaches and detaches .dwg files as an external reference. (XREF)</HelpString>
               <Image ID="xref"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="attachments">
            <Macro>
               <Name>Attachments</Name>
               <Command>^c^c_-toolpanel;"ATTACHMENTS";_S</Command>
               <HelpString>Opens the Attachments panel.</HelpString>
               <Image ID="panel_attachments"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="standards">
            <Macro>
               <Name>Standards...</Name>
               <Command>^c^c_standards</Command>
               <HelpString>Associates one or more drawing standard (DWS) files to the current drawing. (STANDARDS)</HelpString>
               <Image ID="standards"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="checkstandards">
            <Macro>
               <Name>Check Standards</Name>
               <Command>^c^c_checkstandards</Command>
               <HelpString>Checks the current drawing against pre-set standards. (CHECKSTANDARDS)</HelpString>
               <Image ID="check_standards"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="laytrans">
            <Macro>
               <Name>Layer Translator...</Name>
               <Command>^c^c_laytrans</Command>
               <HelpString>Converts the layers in the current drawing to layer standards. (LAYTRANS)</HelpString>
               <Image ID="laytrans"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="profilemanager">
            <Macro>
               <Name>User Profile Manager...</Name>
               <Command>^c^c_profilemanager</Command>
               <HelpString>Opens the User Profile Manager dialog, to create and manage user profiles. (PROFILEMANAGER)</HelpString>
               <Image ID="manage_usage_data"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="appload">
            <Macro>
               <Name>Load Application...</Name>
               <Command>^c^c_appload</Command>
               <HelpString>Opens the Load Application Files dialog, to load application files. (APPLOAD)</HelpString>
               <Image ID="appload"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="menu">
            <Macro>
               <Name>Load CUI...</Name>
               <Command>^c^c_menu</Command>
               <HelpString>Opens the Choose a Customization File dialog, to select a .cui, .cuix, .mnu, .mns, or .icm file to load. (MENU)</HelpString>
               <Image ID="menu"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="menuload">
            <Macro>
               <Name>Customization Groups...</Name>
               <Command>^c^c_menuload</Command>
               <HelpString>Opens the Customization Groups dialog, to load and unload customization groups. (MENULOAD)</HelpString>
               <Image ID="menu"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="wssave">
            <Macro>
               <Name>Save Workspace...</Name>
               <Command>^c^c_wssave</Command>
               <HelpString>Opens the Save Workspace dialog, to save the current workspace under a new name. (WSSAVE)</HelpString>
               <Image ID="workspace_save"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="customize">
            <Macro>
               <Name>Customize...</Name>
               <Command>^c^c_customize</Command>
               <HelpString>Opens the Customize dialog, to customize the user interface. (CUSTOMIZE)</HelpString>
               <Image ID="customize"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="options">
            <Macro>
               <Name>Options...</Name>
               <Command>^c^c_options</Command>
               <HelpString>Opens the Settings dialog. (OPTIONS)</HelpString>
               <Image ID="options"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="hyperlink">
            <Macro>
               <Name>Hyperlink...</Name>
               <Command>^c^c_hyperlink</Command>
               <HelpString>Links an entity that contains fields or web pages, through the Edit Hyperlink dialog. (HYPERLINK)</HelpString>
               <Image ID="url"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="gotostart">
            <Macro>
               <Name>Show Start Page</Name>
               <Command>^c^c_gotostart</Command>
               <HelpString>Opens the Start Page. (GOTOSTART)</HelpString>
               <Image ID="gotostart"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="blade">
            <Macro>
               <Name>LISP Editor</Name>
               <Command>^c^c_blade</Command>
               <HelpString>Opens the BricsCAD LISP Advanced Development Environment, to write and debug LISP code. (BLADE)</HelpString>
               <Image ID="blade"/>
            </Macro>
         </MenuMacro>
      </MacroGroup>
      
      <MacroGroup Name="View">
         <MenuMacro UID="redraw">
            <Macro>
               <Name>Redraw</Name>
               <Command>'_redraw</Command>
               <HelpString>Refreshes the display of the current window. (REDRAW)</HelpString>
               <Image ID="redraw"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="redrawall">
            <Macro>
               <Name>Redraw All</Name>
               <Command>'_redrawall</Command>
               <HelpString>Refreshes the display of all the windows of the current drawing. (REDRAWALL)</HelpString>
               <Image ID="redrawall"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="regen">
            <Macro>
               <Name>Regen</Name>
               <Command>^c^c_regen</Command>
               <HelpString>Regenerates entities in the current viewport. (REGEN)</HelpString>
               <Image ID="regen"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="regenall">
            <Macro>
               <Name>Regen All</Name>
               <Command>^c^c_regenall</Command>
               <HelpString>Regenerates entities in all viewports. (REGENALL)</HelpString>
               <Image ID="regenall"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="rtpan">
            <Macro>
               <Name>Real-Time Pan</Name>
               <Command>'_rtpan</Command>
               <HelpString>Pans the drawing in real-time. (RTPAN)</HelpString>
               <Image ID="rtpan"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="rtzoom">
            <Macro>
               <Name>Real-Time Zoom</Name>
               <Command>'_rtzoom</Command>
               <HelpString>Zooms the viewpoint in and out of the drawing in real-time. (RTZOOM)</HelpString>
               <Image ID="rtzoom"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="zoom">
            <Macro>
               <Name>Zoom</Name>
               <Command>'_zoom</Command>
               <HelpString>Visually changes the size of the drawing within the current viewport. (ZOOM)</HelpString>
               <Image ID="zoom"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="zoom_in">
            <Macro>
               <Name>Zoom In</Name>
               <Command>'_zoom;2x</Command>
               <HelpString>Zooms in by 50%, equivalent to Zoom 2x.</HelpString>
               <Image ID="zoom_in"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="zoom_out">
            <Macro>
               <Name>Zoom Out</Name>
               <Command>'_zoom;.5x</Command>
               <HelpString>Zooms out by 50%, equivalent to Zoom 0.5x.</HelpString>
               <Image ID="zoom_out"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="zoom_window">
            <Macro>
               <Name>Zoom Window</Name>
               <Command>'_zoom;_w</Command>
               <HelpString>Zooms in to a rectangular area.</HelpString>
               <Image ID="zoom_window"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="zoom_extents">
            <Macro>
               <Name>Zoom Extents</Name>
               <Command>'_zoom;_e</Command>
               <HelpString>Zooms to the extents of all entities.</HelpString>
               <Image ID="zoom_extents"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="zoom_previous">
            <Macro>
               <Name>Zoom Previous</Name>
               <Command>'_zoom;_p</Command>
               <HelpString>Displays the previous view, set by the ZOOM, PAN or VIEW commands.</HelpString>
               <Image ID="zoom_previous"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="zoom_all">
            <Macro>
               <Name>Zoom All</Name>
               <Command>'_zoom;_a</Command>
               <HelpString>Displays the entire drawing.</HelpString>
               <Image ID="zoom_all"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="zoom_left">
            <Macro>
               <Name>Zoom Left</Name>
               <Command>'_zoom;_l</Command>
               <HelpString>Zooms in or out with the lower left corner at a point.</HelpString>
               <Image ID="zoom_left"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="zoom_center">
            <Macro>
               <Name>Zoom Center</Name>
               <Command>'_zoom;_c</Command>
               <HelpString>Zooms in or out at a center point.</HelpString>
               <Image ID="zoom_center"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="zoom_right">
            <Macro>
               <Name>Zoom Right</Name>
               <Command>'_zoom;_r</Command>
               <HelpString>Zooms in or out with the lower right corner at a point.</HelpString>
               <Image ID="zoom_right"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="zoom_dynamic">
            <Macro>
               <Name>Zoom Dynamic</Name>
               <Command>'_zoom;_d</Command>
               <HelpString>Pans and zooms with a rectangular box.</HelpString>
               <Image ID="zoom_dynamic"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="zoom_scale">
            <Macro>
               <Name>Zoom Scale</Name>
               <Command>'_zoom;_s</Command>
               <HelpString>Zooms in or out by a scale factor.</HelpString>
               <Image ID="zoom_scale"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="zoom_object">
            <Macro>
               <Name>Zoom to Object</Name>
               <Command>'_zoom;_ob</Command>
               <HelpString>Zooms in on a single entity or a selection.</HelpString>
               <Image ID="zoom"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pan">
            <Macro>
               <Name>Pan</Name>
               <Command>'_pan</Command>
               <HelpString>Pans from side to side, or up and down. (PAN)</HelpString>
               <Image ID="pan"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pan_up">
            <Macro>
               <Name>Pan Up</Name>
               <Command>'_-pan;_u</Command>
               <HelpString>Pans the drawing up by 5% of the current window.</HelpString>
               <Image ID="pan_up"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pan_down">
            <Macro>
               <Name>Pan Down</Name>
               <Command>'_-pan;_d</Command>
               <HelpString>Pans the drawing down by 5% of the current window.</HelpString>
               <Image ID="pan_down"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pan_left">
            <Macro>
               <Name>Pan Left</Name>
               <Command>'_-pan;_l</Command>
               <HelpString>Pans the drawing left by 5% of the current window.</HelpString>
               <Image ID="pan_left"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pan_right">
            <Macro>
               <Name>Pan Right</Name>
               <Command>'_-pan;_r</Command>
               <HelpString>Pans the drawing right by 5% of the current window.</HelpString>
               <Image ID="pan_right"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pan_page_up">
            <Macro>
               <Name>Pan Page Up</Name>
               <Command>'_-pan;_pgu</Command>
               <HelpString>Pans the drawing up by 100% of the current window.</HelpString>
               <Image ID="pan_page_up"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pan_page_down">
            <Macro>
               <Name>Pan Page Down</Name>
               <Command>'_-pan;_pgd</Command>
               <HelpString>Moves the view down by 100% of the current window.</HelpString>
               <Image ID="pan_page_down"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pan_page_left">
            <Macro>
               <Name>Pan Page Left</Name>
               <Command>'_-pan;_pgl</Command>
               <HelpString>Pans the drawing left by 100% of the current window.</HelpString>
               <Image ID="pan_page_left"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pan_page_right">
            <Macro>
               <Name>Pan Page Right</Name>
               <Command>'_-pan;_pgr</Command>
               <HelpString>Moves the view to the right by 100% of the current window.</HelpString>
               <Image ID="pan_page_right"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="rtrot">
            <Macro>
               <Name>Real-Time Constrained Sphere</Name>
               <Command>'_rtrot</Command>
               <HelpString>Real-time, constrained, spherical rotation. (RTROT)</HelpString>
               <Image ID="rtrot"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="rtrotf">
            <Macro>
               <Name>Real-Time Sphere</Name>
               <Command>'_rtrotf</Command>
               <HelpString>Real-time, spherical rotation. (RTROTF)</HelpString>
               <Image ID="rtrotf"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="rtrotx">
            <Macro>
               <Name>Real-Time X</Name>
               <Command>'_rtrotx</Command>
               <HelpString>Real-time, cylindrical rotation, about the X-axis. (RTROTX)</HelpString>
               <Image ID="rtrotx"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="rtroty">
            <Macro>
               <Name>Real-Time Y</Name>
               <Command>'_rtroty</Command>
               <HelpString>Real-time, cylindrical Y-rotation, about the Y-axis. (RTROTY)</HelpString>
               <Image ID="rtroty"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="rtrotz">
            <Macro>
               <Name>Real-Time Z</Name>
               <Command>'_rtrotz</Command>
               <HelpString>Real-time, cylindrical Z-rotation, about the Z-axis. (RTROTZ)</HelpString>
               <Image ID="rtrotz"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="ddvpoint">
            <Macro>
               <Name>Set Viewpoint...</Name>
               <Command>^c^c_ddvpoint</Command>
               <HelpString>Opens the Set Viewpoint dialog, to specify a 3D viewpoint for the current viewport. (DDVPOINT)</HelpString>
               <Image ID="ddvpoint"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="lookfrom">
            <Macro>
               <Name>LookFrom</Name>
               <Command>$M=$(if,$(eq,$(getvar,navvcubedisplay),0),^c^c_lookfrom _on,^c^c_lookfrom _off)</Command>
               <HelpString>Toggles the LookFrom view control on/off. (LOOKFROM)</HelpString>
               <Image ID="viewctl"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="plan">
            <Macro>
               <Name>Plan View</Name>
               <Command>^c^c_plan</Command>
               <HelpString>Displays the drawing top-down, on the XY plane. (PLAN)</HelpString>
               <Image ID="plan"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="viewhorizontal">
            <Macro>
               <Name>View horizontal</Name>
               <Command>^c^c_viewhorizontal</Command>
               <HelpString>Displays the drawing top-down, on the x,y-plane. (VIEWHORIZONTAL)</HelpString>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="camera">
            <Macro>
               <Name>Camera</Name>
               <Command>^c^c_camera</Command>
               <HelpString>Places a camera that points at a target point, in model space and creates named views. (CAMERA)</HelpString>
               <Image ID="camera"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="perspective">
            <Macro>
               <Name>Perspective</Name>
               <Command>'_setvar;PERSPECTIVE;$M=$(if,$(=,0,$(getvar,PERSPECTIVE)),1,0)</Command>
               <HelpString>Toggles perspective view on/off for the current viewport.</HelpString>
               <Image ID="perspective"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="perspective_on">
            <Macro>
               <Name>Perspective On</Name>
               <Command>'_setvar;PERSPECTIVE;1</Command>
               <HelpString>Toggles perspective view on for the current viewport.</HelpString>
               <Image ID="perspective"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="perspective_off">
            <Macro>
               <Name>Perspective Off</Name>
               <Command>'_setvar;PERSPECTIVE;0</Command>
               <HelpString>Toggles perspective view off for the current viewport.</HelpString>
               <Image ID="perspective"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="matchperspective">
            <Macro>
               <Name>Match Perspective</Name>
               <Command>^c^c_matchperspective</Command>
               <HelpString>Matches the current model space view with a background image. (MATCHPERSPECTIVE)</HelpString>
               <Image ID="matchperspective"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dview">
            <Macro>
               <Name>Define View</Name>
               <Command>^c^c_dview</Command>
               <HelpString>Displays a perspective view from a select point. (DVIEW)</HelpString>
               <Image ID="dview"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="view">
            <Macro>
               <Name>Save/Restore View</Name>
               <Command>^c^c_-view</Command>
               <HelpString>Saves, loads or deletes a view. (-VIEW)</HelpString>
               <Image ID="view"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="2dcontext">
            <Macro>
               <Name>2D Context</Name>
               <Command>^c^c._-view;_top;^c_setvar;PERSPECTIVE;0;^c_zoom;_e;^c_-visualstyles;_c;_o;2dwireframe;</Command>
               <HelpString>Sets the current view to 2D context: a plan view with a 2D wireframe visual style.</HelpString>
               <Image ID="2dcontext"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="3dcontext">
            <Macro>
               <Name>3D Context</Name>
               <Command>^c^c._-view;_se;^c_zoom;_e;^c_-visualstyles;_c;_o;modeling;</Command>
               <HelpString>Sets the current view to 3D context: an isometric view, with a modeling visual style.</HelpString>
               <Image ID="3dcontext"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="gradient_bkg_on">
            <Macro>
               <Name>Switch on gradient background</Name>
               <Command>^c^c._gradientbkgon</Command>
               <HelpString>Switches on gradient background, in the current view. (GRADIENTBKGON)</HelpString>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="gradient_bkg_off">
            <Macro>
               <Name>Switch off gradient background</Name>
               <Command>^c^c._gradientbkgoff</Command>
               <HelpString>Switches off gradient background, in the current view. (GRADIENTBKGOFF)</HelpString>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="layout">
            <Macro>
               <Name>Layout</Name>
               <Command>^c^c_layout</Command>
               <HelpString>Creates a new Layout tab and sets the page and plot settings. (LAYOUT)</HelpString>
               <Image ID="layout"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="layout_new">
            <Macro>
               <Name>New Layout</Name>
               <Command>^c^c_layout;_new</Command>
               <HelpString>Creates, copies, renames and deletes layouts. (LAYOUT)</HelpString>
               <Image ID="layout_new"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="layout_next">
            <Macro>
               <Name>Next Layout</Name>
               <Command>^c^c_layout;_neXt</Command>
               <HelpString>Moves to the next layout tab, to the right of the current tab.</HelpString>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="layout_previous">
            <Macro>
               <Name>Previous Layout</Name>
               <Command>^c^c_layout;_Previous</Command>
               <HelpString>Moves to model space or the last active layout tab.</HelpString>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="tilemode_0">
            <Macro>
               <Name>Tilemode Off</Name>
               <Command>^c^c_tilemode;0</Command>
               <HelpString>Moves to model space or the last active layout tab.</HelpString>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="tilemode_1">
            <Macro>
               <Name>Tilemode On</Name>
               <Command>^c^c_tilemode;1</Command>
               <HelpString>Moves to the model space.</HelpString>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="alignspace">
            <Macro>
               <Name>Align Space</Name>
               <Command>^c^c_alignspace</Command>
               <HelpString>Aligns the viewport angle, zoom factor and pan position, based on given points. (ALIGNSPACE)</HelpString>
               <Image ID="alignspace"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="vports">
            <Macro>
               <Name>Viewports</Name>
               <Command>^c^c_vports</Command>
               <HelpString>Creates one or more viewports in model space. (VPORTS)</HelpString>
               <Image ID="vports"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="vports_on">
            <Macro>
               <Name>Show Viewport Entities</Name>
               <Command>^c^c_vports;on</Command>
               <HelpString>Turns viewports on in paper space.</HelpString>
               <Image ID="vport_show"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="vports_off">
            <Macro>
               <Name>Hide Viewport Entities</Name>
               <Command>^c^c_vports;of</Command>
               <HelpString>Turns viewports off in paper space.</HelpString>
               <Image ID="vport_hide"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="vports_single">
            <Macro>
               <Name>Single Viewport</Name>
               <Command>$M=$(if,$(eq,$(getvar,tilemode),1),^c^c_-vports _si,^c^c_-vports)</Command>
               <HelpString>Switches to a single viewport (the current viewport) and removes all other viewports, in model space.</HelpString>
               <Image ID="vports_single"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="vports_polygonal">
            <Macro>
               <Name>Polygonal Viewport</Name>
               <Command>$M=$(if,$(eq,$(getvar,tilemode),0),^c^c_-vports _p,^c^c_-vports)</Command>
               <HelpString>Creates a polygonal viewport, in paper space.</HelpString>
               <Image ID="vports_polygonal"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="vports_convert">
            <Macro>
               <Name>Convert Entity to Viewport</Name>
               <Command>$M=$(if,$(eq,$(getvar,tilemode),0),^c^c_-vports _o,^c^c_-vports)</Command>
               <HelpString>Converts a closed 2D polyline to a viewport, in paper space.</HelpString>
               <Image ID="vports_convert"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="vplayer">
            <Macro>
               <Name>Viewport Layer</Name>
               <Command>^c^c_vplayer</Command>
               <HelpString>Freezes or thaws layers in a viewport.</HelpString>
               <Image ID="vports_layer"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="vpiterator">
            <Macro>
               <Name>Viewport Iterator</Name>
               <Command>^V</Command>
               <HelpString>Cycles through viewports.</HelpString>
               <Image ID="vpiterator"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="mview">
            <Macro>
               <Name>Paper Space Views</Name>
               <Command>^c^c_mview</Command>
               <HelpString>Creates multiple views, in paper space. (MVIEW)</HelpString>
               <Image ID="mview"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="viewbase">
            <Macro>
               <Name>Base Views</Name>
               <Command>^c^c_viewbase</Command>
               <HelpString>Generates associative orthographic and isometric views from a 3D model, in paper space. (VIEWBASE)</HelpString>
               <Image ID="viewbase"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="viewproj">
            <Macro>
               <Name>Projected Views</Name>
