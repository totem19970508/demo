      <MacroGroup Name="Draw">
         <MenuMacro UID="line">
            <Macro>
               <Name>Line</Name>
               <Command>^c^c_line</Command>
               <HelpString>Draws a line. (LINE)</HelpString>
               <Image ID="line"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="ray">
            <Macro>
               <Name>Ray</Name>
               <Command>^c^c_ray</Command>
               <HelpString>Draws a line of infinite length, in one direction, from starting point. (RAY)</HelpString>
               <Image ID="ray"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="xline">
            <Macro>
               <Name>Infinite Line</Name>
               <Command>^c^c_xline</Command>
               <HelpString>Draws a line of infinite length, in both directions, from start point. (XLINE)</HelpString>
               <Image ID="xline"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pline">
            <Macro>
               <Name>Polyline</Name>
               <Command>^c^c_pline</Command>
               <HelpString>Draws a polyline - straight and arc segments. (PLINE)</HelpString>
               <Image ID="pline"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="fit_polyline">
            <Macro>
               <Name>Fit Polyline</Name>
               <Command>^c^c_fitpolyline;_a</Command>
               <HelpString>Draws one, or more, polylines that fit to points on other entities. (FITPOLYLINE)</HelpString>
               <Image ID="fit_pline"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="mline">
            <Macro>
               <Name>Multiline</Name>
               <Command>^c^c_mline</Command>
               <HelpString>Draws a multiline. (MLINE)</HelpString>
               <Image ID="mline"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="fit_line">
            <Macro>
               <Name>Fit Line</Name>
               <Command>^c^c_fitline</Command>
               <HelpString>Draws one, or more, lines that fit to points on other entities. (FITLINE)</HelpString>
               <Image ID="fit_line"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="boundary">
            <Macro>
               <Name>Boundary Polyline...</Name>
               <Command>^c^c_boundary</Command>
               <HelpString>Creates closed polylines from bounding entities. (BOUNDARY)</HelpString>
               <Image ID="boundary"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="spline">
            <Macro>
               <Name>Spline</Name>
               <Command>^c^c_spline</Command>
               <HelpString>Draws a spline. (SPLINE)</HelpString>
               <Image ID="spline"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sketch">
            <Macro>
               <Name>Sketch</Name>
               <Command>^c^c_sketch</Command>
               <HelpString>Draws lines or polylines as freehand sketch. (SKETCH)</HelpString>
               <Image ID="sketch"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="circle">
            <Macro>
               <Name>Circle</Name>
               <Command>^c^c_circle</Command>
               <HelpString>Draws a circle. (CIRCLE)</HelpString>
               <Image ID="circle_r"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="circle_r">
            <Macro>
               <Name>Circle Center-Radius</Name>
               <Command>^c^c_circle;\\</Command>
               <HelpString>Draws a circle from a center point and radius.</HelpString>
               <Image ID="circle_r"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="circle_d">
            <Macro>
               <Name>Circle Center-Diameter</Name>
               <Command>^c^c_circle;\_d;</Command>
               <HelpString>Draws a circle from a center point and diameter.</HelpString>
               <Image ID="circle_d"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="circle_2p">
            <Macro>
               <Name>Circle 2 Points</Name>
               <Command>^c^c_circle;_2p;</Command>
               <HelpString>Draws a circle from 2 points, across the diameter.</HelpString>
               <Image ID="circle_2p"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="circle_3p">
            <Macro>
               <Name>Circle 3 Points</Name>
               <Command>^c^c_circle;_3p;</Command>
               <HelpString>Draws a circle that crosses 3 points.</HelpString>
               <Image ID="circle_3p"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="circle_rt">
            <Macro>
               <Name>Circle Tangent-Tangent-Radius</Name>
               <Command>^c^c_circle;_ttr;</Command>
               <HelpString>Draws a circle from two tangent points and a radius.</HelpString>
               <Image ID="circle_rt"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="circle_ttt">
            <Macro>
               <Name>Circle Tangent-Tangent-Tangent</Name>
               <Command>^c^c_circle;_ttt;</Command>
               <HelpString>Draws a circle from three tangent points.</HelpString>
               <Image ID="circle_ttt"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="circle_a">
            <Macro>
               <Name>Convert Arc to Circle</Name>
               <Command>^c^c_circle;_a;</Command>
               <HelpString>Convert an arc into a circle.</HelpString>
               <Image ID="circle_a"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="arc">
            <Macro>
               <Name>Arc</Name>
               <Command>^c^c_arc</Command>
               <HelpString>Draws a circular arc. (ARC)</HelpString>
               <Image ID="arc_3p"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="arc_3p">
            <Macro>
               <Name>Arc 3-Points</Name>
               <Command>^c^c_arc;\\\</Command>
               <HelpString>Draws an arc through 3 points.</HelpString>
               <Image ID="arc_3p"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="arc_cse">
            <Macro>
               <Name>Arc Center-Start-End</Name>
               <Command>^c^c_arc;_c;\\\</Command>
               <HelpString>Draws an arc from a center, start and then end point.</HelpString>
               <Image ID="arc_cse"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="arc_sce">
            <Macro>
               <Name>Arc Start-Center-End</Name>
               <Command>^c^c_arc;\_c;\\</Command>
               <HelpString>Draws an arc from a start, center, and then end point.</HelpString>
               <Image ID="arc_sce"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="arc_sec">
            <Macro>
               <Name>Arc Start-End-Center</Name>
               <Command>^c^c_arc;\_e;\\</Command>
               <HelpString>Draws an arc from a start, end, and then center point.</HelpString>
               <Image ID="arc_sec"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="arc_t">
            <Macro>
               <Name>Arc Tangent</Name>
               <Command>^c^c_arc;;</Command>
               <HelpString>Draws an arc that continues from the previous entity.</HelpString>
               <Image ID="arc_t"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="arc_csa">
            <Macro>
               <Name>Arc Center-Start-Angle</Name>
               <Command>^c^c_arc;_c;\\_a;</Command>
