      <MacroGroup Name="Images">
         <MenuMacro UID="img_attach">
            <Macro>
               <Name>Attach Raster Image</Name>
               <Command>^c^c_imageattach</Command>
               <HelpString>Attaches a raster image. (IMAGEATTACH)</HelpString>
               <Image ID="img_attach"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="img_manage">
            <Macro>
               <Name>Image Management</Name>
               <Command>^c^c_image</Command>
               <HelpString>Manages raster images. (IMAGE)</HelpString>
               <Image ID="img_manage"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="img_edit">
            <Macro>
               <Name>Image Adjust</Name>
               <Command>^c^c_imageadjust</Command>
               <HelpString>Adjusts raster image properties. (IMAGEADJUST)</HelpString>
               <Image ID="img_edit"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="img_transparency">
            <Macro>
               <Name>Image Transparency</Name>
               <Command>^c^c_transparency</Command>
               <HelpString>Turns raster transparency on/off. (TRANSPARENCY)</HelpString>
               <Image ID="img_transparency"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="img_quality">
            <Macro>
               <Name>Image Quality</Name>
               <Command>^c^c_imagequality</Command>
               <HelpString>Toggles image quality high/draft. (IMAGEQUALITY)</HelpString>
               <Image ID="img_quality"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="img_frame">
            <Macro>
               <Name>Display Image Frame</Name>
               <Command>^c^c_imageframe</Command>
               <HelpString>Turns image frames on/off. (IMAGEFRAME)</HelpString>
               <Image ID="img_frame"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="img_clip">
            <Macro>
               <Name>Clip Image</Name>
               <Command>^c^c_imageclip</Command>
               <HelpString>Clips raster images. (IMAGECLIP)</HelpString>
               <Image ID="img_clip"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="img_iembed">
            <Macro>
               <Name>Embed Image</Name>
               <Command>^c^c_iembed</Command>
               <HelpString> Saves a render image (bitonal .tiff) image inside the current drawing. (IEMBED)</HelpString>
               <Image ID="img_iembed"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="img_iunembed">
            <Macro>
               <Name>Un-embed Image</Name>
               <Command>^c^c_iunembed</Command>
               <HelpString>Extracts an embedded raster (bitonal .tiff) image to a file. (IUNEMBED)</HelpString>
               <Image ID="img_iunembed"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="img_isaveas">
            <Macro>
               <Name>Export Image</Name>
               <Command>^c^c_isaveas</Command>
               <HelpString>Exports a raster image to a file. (ISAVEAS)</HelpString>
               <Image ID="img_isaveas"/>
            </Macro>
         </MenuMacro>
