         </MenuMacro>
         <MenuMacro UID="setlicenselevelmechanical">
            <Macro>
               <Name>Run as BricsCAD Mechanical</Name>
               <Command>^c^c_setlicenselevel;_bricscad;_mechanical;</Command>
               <HelpString>Runs BricsCAD at the BricsCAD Mechanical license level, if the license is available. A restart is required.</HelpString>
