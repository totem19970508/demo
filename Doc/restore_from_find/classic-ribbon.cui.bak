               <Image ID="mirror"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="mirror3d">
            <Macro>
               <Name>3D Mirror</Name>
               <Command>^c^c_mirror3d</Command>
               <HelpString>Mirrors entities along a plane. (MIRROR3D)</HelpString>
               <Image ID="mirror3d"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="copyguided3d">
            <Macro>
               <Name>3D Copy Guided</Name>
               <Command>^c^c_copyguided3d</Command>
               <HelpString>Copies 3D Solids or Block references from one location to another, using reference faces. (COPYGUIDED3D)</HelpString>
               <Image ID="copyguided_3d"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="arrayclassic">
            <Macro>
               <Name>Array Dialog Box</Name>
