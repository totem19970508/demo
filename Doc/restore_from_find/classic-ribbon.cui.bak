                     <Property ID="CustomScale"/>
                     <Property ID="VisualStyle"/>
                  </Rollover>
               </Entity>
            </PropertyGroup>
            <PropertyGroup Name="Face">
               <Rollover>
                  <Property ID="Area"/>
               </Rollover>
            </PropertyGroup>
            <PropertyGroup Name="Edge">
               <Rollover>
                  <Property ID="Length"/>
                  <Property ID="Slope"/>
                  <Property ID="UCSElevation"/>
               </Rollover>
            </PropertyGroup>
            <PropertyGroup Name="Vertex">
               <Rollover>
                  <Property ID="PositionPoint"/>
                  <Property ID="UCSElevation"/>
               </Rollover>
            </PropertyGroup>
            <Entity Name="Boundary">
               <Rollover>
                  <Property ID="Perimeter"/>
                  <Property ID="Area"/>
               </Rollover>
            </Entity>
            <PropertyGroup Name="Extensions">
               <Application Name="BIM">
                  <Entity Name="BIM_BEAM">
                     <Rollover>
                        <Property Application="BIM" ID="BeamType"/>
                        <Property Application="BIM" ID="Composition"/>
                        <Property Application="BIM" ID="Length"/>
                     </Rollover>
                  </Entity>
                  <Entity Name="BIM_COLUMN">
                     <Rollover>
                        <Property Application="BIM" ID="ColumnType"/>
                        <Property Application="BIM" ID="Composition"/>
                        <Property Application="BIM" ID="Height"/>
                     </Rollover>
                  </Entity>
                  <Entity Name="BIM_COVERING">
                     <Rollover>
                        <Property Application="BIM" ID="CoveringType"/>
                        <Property Application="BIM" ID="Composition"/>
                     </Rollover>
                  </Entity>
                  <Entity Name="BIM_RAILING">
                     <Rollover>
                        <Property Application="BIM" ID="RailingType"/>
                        <Property Application="BIM" ID="Composition"/>
                     </Rollover>
                  </Entity>
                  <Entity Name="BIM_ROOF">
                     <Rollover>
                        <Property Application="BIM" ID="RoofType"/>
                        <Property Application="BIM" ID="Composition"/>
                     </Rollover>
                  </Entity>
                  <Entity Name="BIM_SLAB">
                     <Rollover>
                        <Property Application="BIM" ID="SlabType"/>
                        <Property Application="BIM" ID="Composition"/>
                        <Property Application="BIM" ID="FootprintArea"/>
                     </Rollover>
                  </Entity>
                  <Entity Name="BIM_STAIR">
                     <Rollover>
                        <Property Application="BIM" ID="StairType"/>
                        <Property Application="BIM" ID="Composition"/>
                     </Rollover>
                  </Entity>
                  <Entity Name="BIM_WALL">
                     <Rollover>
                        <Property Application="BIM" ID="WallType"/>
                        <Property Application="BIM" ID="Composition"/>
                        <Property Application="BIM" ID="NetSideArea"/>
                     </Rollover>
                  </Entity>
               </Application>
            </PropertyGroup>
