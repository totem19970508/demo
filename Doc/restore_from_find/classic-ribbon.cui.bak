            </Macro>
         </MenuMacro>
         <MenuMacro UID="color_magenta">
            <Macro>
               <Name>Magenta</Name>
               <Command>'_-color;_magenta</Command>
               <HelpString>Sets the current color to magenta.</HelpString>
               <Image ID="color_magenta"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="color_white">
            <Macro>
               <Name>White</Name>
               <Command>'_-color;_white</Command>
               <HelpString>Sets the current color to white.</HelpString>
               <Image ID="color_white"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="fill_t">
            <Macro>
               <Name>Fill</Name>
               <Command>^c^c_fill;_t</Command>
               <HelpString>Toggles the display of filled and hatched areas and controls if wide polylines, traces, solids, hatches (including solid-fill and wide polylines) are filled in.</HelpString>
               <Image ID="fill_t"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="limits">
            <Macro>
               <Name>Drawing Limits</Name>
               <Command>_limits</Command>
               <HelpString>Sets an imaginary boundary for the extents of the drawing and optionally, the grid. (LIMITS)</HelpString>
               <Image ID="limits"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="limits_t">
            <Macro>
               <Name>Drawing Limits</Name>
               <Command>_limits;_t</Command>
               <HelpString>Toggles the drawing limits on/off</HelpString>
               <Image ID="limits"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="base">
            <Macro>
               <Name>Base Point</Name>
               <Command>^c^c_base</Command>
               <HelpString>Sets the base insertion point. (BASE)</HelpString>
               <Image ID="base"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="elevation">
            <Macro>
               <Name>Elevation</Name>
               <Command>^c^c_elevation</Command>
               <HelpString>Sets the elevation for new entities, relative to the current UCS. (ELEVATION)</HelpString>
               <Image ID="elevation"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="thickness">
            <Macro>
               <Name>Thickness</Name>
               <Command>^c^c_thickness</Command>
               <HelpString>Sets the thickness for new entities. (THICKNESS)</HelpString>
               <Image ID="thickness"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="setucs">
            <Macro>
               <Name>UCS...</Name>
               <Command>^c^c_setucs</Command>
               <HelpString>Opens the User Coordinate System dialog, to set a viewpoint to for the current User Coordinate System. (SETUCS)</HelpString>
               <Image ID="setucs"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="ucs">
            <Macro>
               <Name>UCS</Name>
               <Command>^c^c_ucs</Command>
               <HelpString>Creates and displays user-defined coordinate systems (UCS) in the Command line. (UCS)</HelpString>
               <Image ID="ucs"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="ucs_world">
            <Macro>
               <Name>UCS World</Name>
               <Command>^c^c_ucs;_w</Command>
               <HelpString>Sets the UCS to World Coordinate System.</HelpString>
               <Image ID="ucs_world"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="ucs_previous">
            <Macro>
               <Name>UCS Previous</Name>
               <Command>^c^c_ucs;_p</Command>
               <HelpString>Restores the previous UCS.</HelpString>
               <Image ID="ucs_previous"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="ucs_face">
            <Macro>
               <Name>UCS Face</Name>
               <Command>^c^c_ucs;_f</Command>
               <HelpString>Aligns the UCS to a planar (flat) entity.</HelpString>
               <Image ID="ucs_face"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="ucs_entity">
            <Macro>
               <Name>UCS Entity</Name>
               <Command>^c^c_ucs;_e</Command>
               <HelpString>Aligns the UCS to an entity.</HelpString>
               <Image ID="ucs_entity"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="ucs_view">
            <Macro>
               <Name>UCS View</Name>
               <Command>^c^c_ucs;_v</Command>
               <HelpString>Aligns the UCS to the current view.</HelpString>
               <Image ID="ucs_view"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="ucs_x">
            <Macro>
               <Name>UCS Rotate X</Name>
               <Command>^c^c_ucs;_x</Command>
               <HelpString>Rotates the UCS around the X axis.</HelpString>
               <Image ID="ucs_x"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="ucs_y">
            <Macro>
               <Name>UCS Rotate Y</Name>
               <Command>^c^c_ucs;_y</Command>
               <HelpString>Rotates the UCS around the Y axis.</HelpString>
               <Image ID="ucs_y"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="ucs_z">
            <Macro>
               <Name>UCS Rotate Z</Name>
               <Command>^c^c_ucs;_z</Command>
               <HelpString>Rotates the UCS around the Z axis.</HelpString>
               <Image ID="ucs_z"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="ucs_zaxis">
            <Macro>
               <Name>UCS Z Axis</Name>
               <Command>^c^c_ucs;_za</Command>
               <HelpString>Aligns the UCS to a Z axis.</HelpString>
               <Image ID="ucs_zaxis"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="ucs_move">
            <Macro>
               <Name>UCS Move</Name>
               <Command>^c^c_ucs;_move</Command>
               <HelpString>Moves the UCS.</HelpString>
               <Image ID="ucs_move"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="ucs_origin">
            <Macro>
               <Name>UCS Origin</Name>
               <Command>^c^c_ucs;_origin</Command>
               <HelpString>Defines the UCS by new origin point.</HelpString>
               <Image ID="ucs_origin"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="ucs_3p">
            <Macro>
               <Name>UCS 3 Points</Name>
               <Command>^c^c_ucs;_3</Command>
               <HelpString>Defines the UCS by three points.</HelpString>
               <Image ID="ucs_3p"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="ucsicon">
            <Macro>
               <Name>UCS Icon</Name>
               <Command>$M=$(if,$(and,$(getvar,UCSICON),1),^c^c_ucsicon;_off,^c^c_ucsicon;_on)</Command>
               <HelpString>Toggles the display of the UCS icon on/off.</HelpString>
               <Image ID="ucs_view"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="laymcur">
            <Macro>
               <Name>Set Layer by Entity</Name>
               <Command>^c^c_laymcur</Command>
               <HelpString>Sets the current layer to the same as an entity. (LAYMCUR)</HelpString>
               <Image ID="laymcur"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="laycur">
            <Macro>
               <Name>Move to Current Layer</Name>
               <Command>^c^c_laycur</Command>
               <HelpString>Moves entities to the current layer. (LAYCUR)</HelpString>
               <Image ID="laycur"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="layerp">
            <Macro>
               <Name>Layer Previous</Name>
               <Command>^c^c_layerp</Command>
               <HelpString>Undoes previously applied changes to layer settings - if LAYERPMODE is ON. (LAYERP)</HelpString>
               <Image ID="layerp"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="layon">
            <Macro>
               <Name>Layers On</Name>
               <Command>^c^c_layon</Command>
               <HelpString>Switches all layers on. (LAYON)</HelpString>
               <Image ID="layon"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="layoff">
            <Macro>
               <Name>Layer Off</Name>
               <Command>^c^c_layoff</Command>
               <HelpString>Switches off a layer by entity. (LAYOFF)</HelpString>
               <Image ID="layoff"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="laylck">
            <Macro>
               <Name>Lock Layer</Name>
               <Command>^c^c_laylck</Command>
               <HelpString>Locks the layer by entity. (LAYLCK)</HelpString>
               <Image ID="laylck"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="layulk">
            <Macro>
               <Name>Unlock Layer</Name>
               <Command>^c^c_layulk</Command>
               <HelpString>Unlocks the layer by entity. (LAYULK)</HelpString>
               <Image ID="layulk"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="layfrz">
            <Macro>
               <Name>Freeze Layer</Name>
               <Command>^c^c_layfrz</Command>
               <HelpString>Freezes the layer by entity. (LAYFRZ)</HelpString>
               <Image ID="layfrz"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="laythw">
            <Macro>
               <Name>Thaw All Layers</Name>
               <Command>^c^c_laythw</Command>
               <HelpString>Thaws all layers. (LAYTHW)</HelpString>
               <Image ID="laythw"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="layiso">
            <Macro>
               <Name>Isolate Layer</Name>
               <Command>^c^c_layiso</Command>
               <HelpString>Hides or locks all layers, except those of currently select entities. (LAYISO)</HelpString>
               <Image ID="layiso"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="layuniso">
            <Macro>
               <Name>Unisolate Layer</Name>
               <Command>^c^c_layuniso</Command>
               <HelpString>Switches on all layers, that were switched off with the last LAYISO command. (LAYUNISO)</HelpString>
               <Image ID="layuniso"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="setvar">
            <Macro>
               <Name>Set Variable</Name>
               <Command>^c^c_setvar</Command>
               <HelpString>Displays and changes the values of system variables in the Command line. (SETVAR)</HelpString>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="settings">
            <Macro>
               <Name>Settings...</Name>
               <Command>^c^c_settings</Command>
               <HelpString>Opens the Settings dialog. (SETTINGS)</HelpString>
               <Image ID="settings"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dsettings">
            <Macro>
               <Name>Drafting Settings...</Name>
               <Command>^c^c_dsettings</Command>
               <HelpString>Opens the Settings dialog and displays the Snap and Grid settings. (DSETTINGS)</HelpString>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="ddselect">
            <Macro>
               <Name>Selection Settings...</Name>
               <Command>^c^c_ddselect</Command>
               <HelpString>Opens the Settings dialog and displays the Entity Selection settings. (DDSELECT)</HelpString>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="ddgrips">
            <Macro>
               <Name>Grips Settings...</Name>
               <Command>^c^c_ddgrips</Command>
               <HelpString>Opens the Settings dialog box and displays the Grip settings. (DDGRIPS)</HelpString>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="units">
            <Macro>
               <Name>Drawing Units...</Name>
               <Command>^c^c_units</Command>
               <HelpString>Opens the Settings dialog box and displays the Unit settings. (UNITS)</HelpString>
               <Image ID="units"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pdmode">
            <Macro>
               <Name>Point Display Mode</Name>
               <Command>^c^c_settingssearch;PDMODE</Command>
               <HelpString>Opens the Settings dialog for the Point Display Mode settings. (PDMODE)</HelpString>
               <Image ID="settings"/>
            </Macro>
         </MenuMacro>
      </MacroGroup>
      <MacroGroup Name="Sheet Metal">
         <MenuMacro UID="sm_sheet">
            <Macro>
               <Name>Create Base Flange</Name>
               <Command>^c^c_smFlange</Command>
               <HelpString>Creates a base (initial) sheet metal part flange from a closed, planar (flat) profile. (SMFLANGE)</HelpString>
               <Image ID="sm_sheet"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_flange_edge">
            <Macro>
               <Name>Create Edge Flange</Name>
               <Command>^c^c_smFlangeEdge</Command>
               <HelpString>Pulls the edge of a sheet metal part flange, to create a flange. (SMFLANGEEDGE)</HelpString>
               <Image ID="sm_flange_edge"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_flange_edge_material_outside">
            <Macro>
               <Name>Create Edge Flange Outside </Name>
               <Command>^c^c_smFlangeEdge;_MO</Command>
               <HelpString>Pulls the edge of a sheet metal part flange, to create a flange on the outside. (SMFLANGEEDGE)</HelpString>
               <Image ID="sm_flange_edge_material_outside"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_hem_closed">
            <Macro>
               <Name>Create Closed Hem</Name>
               <Command>^c^c_smHem;</Command>
               <HelpString>Pulls the edge of a sheet metal part flange, to create a closed hem. (SMHEM)</HelpString>
               <Image ID="sm_hem_closed"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_hem_open">
            <Macro>
               <Name>Create Open Hem</Name>
               <Command>^c^c_smHem;_H</Command>
               <HelpString>Pulls the edge of a sheet metal part flange, to create an open hem.</HelpString>
               <Image ID="sm_hem_open"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_hem_teardrop">
            <Macro>
               <Name>Create Teardrop Hem</Name>
               <Command>^c^c_smHem;_T</Command>
               <HelpString>Pulls the edge of a sheet metal part flange, to create a teardrop hem.</HelpString>
               <Image ID="sm_hem_teardrop"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_hem_round">
            <Macro>
               <Name>Create Round Hem</Name>
               <Command>^c^c_smHem;_R</Command>
               <HelpString>Pulls the edge of a sheet metal part flange, to create a round hem.</HelpString>
               <Image ID="sm_hem_round"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_flange_rotate">
            <Macro>
               <Name>Rotate Flange</Name>
               <Command>^c^c_smRotate</Command>
               <HelpString>Rotates a sheet metal flange. (SMROTATE)</HelpString>
               <Image ID="sm_flange_rotate"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_flangeconnect">
            <Macro>
               <Name>Connect Flanges</Name>
               <Command>^c^c_smFlangeConnect</Command>
               <HelpString>Connects a pair of sheet metal flanges and forms a closed junction. (SMFLANGECONNECT)</HelpString>
               <Image ID="sm_connect"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_flange_contour">
            <Macro>
               <Name>Create Flange from a Closed Contour</Name>
               <Command>^c^c_smFlangeContour</Command>
               <HelpString>Creates a sheet metal flange from a closed contour and automatically attaches it to a sheet metal part already in the drawing. (SMFLANGECONTOUR)</HelpString>
               <Image ID="sm_flange_contour"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_unfold">
            <Macro>
               <Name>Unfold Body</Name>
               <Command>^c^c_smUnfold</Command>
               <HelpString>Unfolds a sheet metal part. (SMUNFOLD)</HelpString>
               <Image ID="sm_unfold"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_unfold_associativity">
            <Macro>
               <Name>Associatively Unfold Body</Name>
               <Command>^c^c_smUnfold;_A;</Command>
               <HelpString>Opens an additional window with an unfolded representation of the sheet metal part. The windows have bidirectional associativity; if something is changed it one window, the other window updates automatically.</HelpString>
               <Image ID="sm_associative_unfolding"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_convert">
            <Macro>
               <Name>Convert to Sheet Metal</Name>
               <Command>^c^c_smConvert</Command>
               <HelpString>Converts a 3D solid to a sheet metal part. (SMCONVERT)</HelpString>
               <Image ID="sm_convert"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_quick">
            <Macro>
               <Name>Quick Create Unfoldable Part</Name>
               <Command>^c^c_smQuick</Command>
               <HelpString>Converts a solid to sheetmetal and automatically creates the optimal set of splits, junctions and bends. (SMQUICK)</HelpString>
               <Image ID="sm_quick"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_dissolve">
            <Macro>
               <Name>Dissolve</Name>
               <Command>^c^c_smDissolve</Command>
               <HelpString>Removes Sheet Metal data from a sheet metal part. (SMDISSOLVE)</HelpString>
               <Image ID="sm_dissolve"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_explode">
            <Macro>
               <Name>Explode Features</Name>
               <Command>*^c^c_smExplode</Command>
               <HelpString>Explodes sheet metal features into a combination of the most basic features: flanges, bends, lofted bends and junctions. (SMEXPLODE)</HelpString>
               <Image ID="explode"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_reliefcreate">
            <Macro>
               <Name>Create Relief</Name>
               <Command>*^c^c_smRelief;\;</Command>
               <HelpString>Creates corner and bend reliefs on a sheet metal part. (SMRELIEF)</HelpString>
               <Image ID="sm_relief_create"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_c_reliefswitch">
            <Macro>
               <Name>Switch to Circular Relief</Name>
               <Command>*^c^c_smReliefSwitch;_CI;\;</Command>
               <HelpString>Switches corner reliefs to circular reliefs.</HelpString>
               <Image ID="sm_c_relief_switch"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_r_reliefswitch">
            <Macro>
               <Name>Switch to Rectangular Relief</Name>
               <Command>*^c^c_smReliefSwitch;_REC;\;</Command>
               <HelpString>Switches select bend reliefs or corner reliefs, to rectangular reliefs.</HelpString>
               <Image ID="sm_relief_switch"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_v_reliefswitch">
            <Macro>
               <Name>Switch to V-Type Relief</Name>
               <Command>*^c^c_smReliefSwitch;\;</Command>
               <HelpString>Switches corner reliefs to V-type reliefs.</HelpString>
               <Image ID="sm_v_relief_switch"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_smooth_reliefswitch">
            <Macro>
               <Name>Switch to Smooth Relief</Name>
               <Command>*^c^c_smReliefSwitch;_SM;\;</Command>
               <HelpString>Switches bend reliefs to smooth reliefs.</HelpString>
               <Image ID="sm_b_relief_switch_smooth"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_round_reliefswitch">
            <Macro>
               <Name>Switch to Round Relief</Name>
               <Command>*^c^c_smReliefSwitch;_RO;\;</Command>
               <HelpString>Switches the bend reliefs to round reliefs.</HelpString>
               <Image ID="sm_b_relief_switch_round"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_rip_reliefswitch">
            <Macro>
               <Name>Switch to Rip Relief</Name>
               <Command>*^c^c_smReliefSwitch;_RI;\;</Command>
               <HelpString>Switches bend reliefs to rip reliefs.</HelpString>
               <Image ID="sm_b_relief_switch_rip"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_delete">
            <Macro>
               <Name>Delete Feature</Name>
               <Command>^c^c_smDelete</Command>
               <HelpString>Removes features from sheet metal elements. (SMDELETE)</HelpString>
               <Image ID="sm_delete"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_repair">
            <Macro>
               <Name>Repair Sheet Metal</Name>
               <Command>^c^c_smRepair</Command>
               <HelpString>Restores the 3D solid model of a sheet metal part. (SMREPAIR)</HelpString>
               <Image ID="repair_loft"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_repair_local">
            <Macro>
               <Name>Repair Sheet Metal Locally</Name>
               <Command>^c^c_smRepair;_L;</Command>
               <HelpString>Repairs a sheet metal part flange face, lofted bend face, thickness face, or side edge.</HelpString>
               <Image ID="repair_local"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_rollededge">
            <Macro>
               <Name>Create Rolled Edge</Name>
               <Command>^c^c_smRollededge</Command>
               <HelpString>Creates rolled edges on curved, sheet metal flanges. (SMROLLEDEDGE)</HelpString>
               <Image ID="sm_rollededgecreate"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_extrude">
            <Macro>
               <Name>Extrude Polyline</Name>
               <Command>^c^c_smExtrude</Command>
               <HelpString>Extrudes a polyline into a sheet metal profile. (SMEXTRUDE)</HelpString>
               <Image ID="sm_extrude"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_imprint">
            <Macro>
               <Name>Split Thickness Face</Name>
               <Command>^c^c_smImprint</Command>
               <HelpString>Imprints edges, to split the thickness faces of a sheet metal part. (SMIMPRINT)</HelpString>
               <Image ID="sm_imprint"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_common_flangesplit">
            <Macro>
               <Name>Split</Name>
               <Command>*^c^c_smSplit</Command>
               <HelpString>Splits a sheet metal flange along a polyline drawn along a face or lofted bends along a line on the ruled surface. (SMSPLIT)</HelpString>
               <Image ID="sm_split"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_smart_flangesplit">
            <Macro>
               <Name>Smart Split</Name>
               <Command>*^c^c_smSplit;_Smart;</Command>
               <HelpString>Automatically splits a sheet metal flange on sheet metal flange faces or lofted bends. (SMSPLIT)</HelpString>
               <Image ID="sm_split_smart"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_smart_propagate_flangesplit">
            <Macro>
               <Name>Smart Split Propagate</Name>
               <Command>*^c^c_smSplit;_Smart;_P;</Command>
               <HelpString>Propagates splits on a sheet metal, flange faces or lofted bends. (SMSPLIT)</HelpString>
               <Image ID="sm_split_smart_propagate"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_smart_propagate_flange_face_splits">
            <Macro>
               <Name>Suggest Splits on Face</Name>
               <Command>*^c^c_smSplit;_Smart;_F</Command>
               <HelpString>Suggest optimal splits on a sheet metal, flange faces and lofted bends. (SMSPLIT)</HelpString>
               <Image ID="sm_split_auto"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_cmd_form_create">
            <Macro>
               <Name>Define from Faces</Name>
               <Command>*^c^c_smForm;</Command>
               <HelpString>Creates a sheet metal form feature. (SMFORM)</HelpString>
               <Image ID="sm_form_create"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_formfeature_insert">
            <Macro>
               <Name>Insert Form Feature</Name>
               <Command>^c^c_bmInsert</Command>
               <HelpString>Inserts a form feature onto a sheet metal flange. (BMINSERT)</HelpString>
               <Image ID="form"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sm_cmd_form_explode">
            <Macro>
               <Name>Explode into Flanges and Bends</Name>
               <Command>*^c^c_smForm;_E;</Command>
