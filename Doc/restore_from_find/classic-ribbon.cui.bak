      <MacroGroup Name="Entity Snaps">
         <MenuMacro UID="osnap_endpoint">
            <Macro>
               <Name>Snap to Endpoint</Name>
               <Command>_endpoint</Command>
               <HelpString>Snaps to the closest endpoint of an entity. (ENDPOINT)</HelpString>
               <Image ID="osnap_endpoint"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="osnap_midpoint">
            <Macro>
               <Name>Snap to Midpoint</Name>
               <Command>_midpoint</Command>
               <HelpString>Snaps to the midpoint of an entity. (MIDPOINT)</HelpString>
               <Image ID="osnap_midpoint"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="osnap_center">
            <Macro>
               <Name>Snap to Center</Name>
               <Command>_center</Command>
               <HelpString>Snaps to the center of an arc, circle, ellipse, or elliptical arc. (CENTER)</HelpString>
               <Image ID="osnap_center"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="osnap_perpendicular">
            <Macro>
               <Name>Snap to Perpendicular</Name>
               <Command>_perpendicular</Command>
               <HelpString>Snaps to a point perpendicular to an entity. (PERPENDICULAR)</HelpString>
               <Image ID="osnap_perpendicular"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="osnap_tangent">
            <Macro>
               <Name>Snap to Tangent</Name>
               <Command>_tangent</Command>
               <HelpString>Snaps to the tangent of an arc, circle, ellipse, elliptical arc, or spline. (TANGENT)</HelpString>
               <Image ID="osnap_tangent"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="osnap_quadrant">
            <Macro>
               <Name>Snap to Quadrant</Name>
               <Command>_quadrant</Command>
               <HelpString>Snaps to a quadrant point of an arc, circle, ellipse, or elliptical arc. (QUADRANT)</HelpString>
               <Image ID="osnap_quadrant"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="osnap_insertion">
            <Macro>
               <Name>Snap to Insertion</Name>
               <Command>_insertion</Command>
               <HelpString>Snaps to the insertion point of entities such as text, blocks, or attributes. (INSERTION)</HelpString>
               <Image ID="osnap_insertion"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="osnap_node">
            <Macro>
               <Name>Snap to Node</Name>
               <Command>_node</Command>
               <HelpString>Snaps to a point entity. (NODE)</HelpString>
               <Image ID="osnap_node"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="osnap_nearest">
            <Macro>
               <Name>Snap to Nearest</Name>
               <Command>_nearest</Command>
               <HelpString>Snaps to the nearest point on an entity. (NEAREST)</HelpString>
               <Image ID="osnap_nearest"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="osnap_intersection">
            <Macro>
               <Name>Snap to Intersection</Name>
               <Command>_intersection</Command>
               <HelpString>Snaps to the intersection of two entities. (INTERSECTION)</HelpString>
               <Image ID="osnap_intersection"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="osnap_apparent">
            <Macro>
               <Name>Snap to Apparent Intersection</Name>
               <Command>_apparent</Command>
               <HelpString>Snaps to the apparent intersection of two entities. (APPARENT)</HelpString>
               <Image ID="osnap_apparent"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="osnap_extension">
            <Macro>
               <Name>Snap to Extension</Name>
               <Command>_extension</Command>
               <HelpString>Snaps to the phantom extension of an arc or line. (EXTENSION)</HelpString>
               <Image ID="osnap_extension"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="osnap_none">
            <Macro>
               <Name>Clear Entity Snaps</Name>
               <Command>_none</Command>
               <HelpString>Turns 2D entity snaps off. (NONE)</HelpString>
               <Image ID="osnap_none"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="osnap_gcenter">
            <Macro>
               <Name>Snap to Geometric Center</Name>
               <Command>_gcenter</Command>
               <HelpString>Snaps to the geometric center of a closed polyline, spline or face. (GCENTER)</HelpString>
               <Image ID="osnap_gcenter"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="osnap_parallel">
            <Macro>
               <Name>Snap to Parallel</Name>
               <Command>_parallel</Command>
               <HelpString>Snaps parallel to a given line. (PARALLEL)</HelpString>
               <Image ID="osnap_parallel"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="osnap_t">
            <Macro>
               <Name>2D Entity snap toggle</Name>
               <Command>'_-osnap;_t</Command>
               <HelpString>Toggles 2D entity snaps on/off.</HelpString>
               <Image ID="osnap"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="osnap_from">
            <Macro>
               <Name>From</Name>
               <Command>_from</Command>
               <HelpString>Locates a point offset from a reference point, within a command. (FROM)</HelpString>
               <Image ID="osnap_from"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="osnap_m2p">
            <Macro>
               <Name>Snap to Middle of 2 Points</Name>
               <Command>_m2p</Command>
               <HelpString>Snaps to the middle of 2 points. (M2P)</HelpString>
               <Image ID="osnap_m2p"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="osnap_tt">
            <Macro>
               <Name>Temporary tracking point</Name>
               <Command>_tt</Command>
               <HelpString>Defines a single temporary tracking point. (TT)</HelpString>
               <Image ID="osnap_tt"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="osnap_tk">
            <Macro>
               <Name>Temporary tracking points</Name>
               <Command>_tk</Command>
               <HelpString>Defines multiple temporary tracking points. (TK)</HelpString>
               <Image ID="osnap_tk"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="osnapz">
            <Macro>
               <Name>Ignore entity snap elevation</Name>
               <Command>'_setvar;OSNAPZ;$M=$(if,$(=,0,$(getvar,OSNAPZ)),1,0)</Command>
               <HelpString>Replaces Z coordinate of entity snapping point with current value of ELEVATION system variable.</HelpString>
               <Image ID="osnapz"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="osnap_hatch">
            <Macro>
               <Name>Entity snap to hatches</Name>
               <Command>'_setvar;OSOPTIONS;$M=$(if,$(&gt;,0,$(getvar,OSOPTIONS)),1,$(xor,$(getvar,OSOPTIONS),1))</Command>
               <HelpString>Snaps to points on hatches.</HelpString>
               <Image ID="osnap_hatch"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="osnap_negative_z">
            <Macro>
               <Name>Entity snap to negative-z</Name>
               <Command>'_setvar;OSOPTIONS;$M=$(if,$(&gt;,0,$(getvar,OSOPTIONS)),2,$(xor,$(getvar,OSOPTIONS),2))</Command>
               <HelpString>Snaps to negative-z coordinates while in dynamic UCS.</HelpString>
               <Image ID="osnap_negative_z"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="osnap_dim_ext">
            <Macro>
               <Name>Entity snap to dimension lines</Name>
               <Command>'_setvar;OSOPTIONS;$M=$(if,$(&gt;,0,$(getvar,OSOPTIONS)),4,$(xor,$(getvar,OSOPTIONS),4))</Command>
               <HelpString>Snaps to dimension extension line endpoints.</HelpString>
               <Image ID="osnap_dim_ext"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="osnap_visible">
            <Macro>
               <Name>Entity snap to visible geometry only</Name>
               <Command>'_setvar;OSOPTIONS;$M=$(xor,$(getvar,OSOPTIONS),8)</Command>
               <HelpString>Ignore invisible snapping points</HelpString>
               <Image ID="osnap_visible"/>
            </Macro>
         </MenuMacro>
      </MacroGroup>
