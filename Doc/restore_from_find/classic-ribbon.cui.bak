      <MacroGroup Name="Meshes">
         <MenuMacro UID="wedge">
            <Macro>
               <Name>Wedge</Name>
               <Command>^c^c_ai_wedge</Command>
               <HelpString>Draws a mesh wedge.</HelpString>
               <Image ID="wedge"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pyramid">
            <Macro>
               <Name>Pyramid</Name>
               <Command>^c^c_ai_pyramid</Command>
               <HelpString>Draws a mesh pyramid, or tetrahedron.</HelpString>
               <Image ID="pyramid"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="box">
            <Macro>
               <Name>Box</Name>
               <Command>^c^c_ai_box</Command>
               <HelpString>Draws a mesh box.</HelpString>
               <Image ID="box"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="cone">
            <Macro>
               <Name>Cone</Name>
               <Command>^c^c_ai_cone</Command>
               <HelpString>Draws a mesh cone.</HelpString>
               <Image ID="cone"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="cylinder">
            <Macro>
               <Name>Cylinder</Name>
               <Command>^c^c_ai_cylinder</Command>
               <HelpString>Draws a mesh cylinder.</HelpString>
               <Image ID="cylinder"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="sphere">
            <Macro>
               <Name>Sphere</Name>
               <Command>^c^c_ai_sphere</Command>
               <HelpString>Draws a mesh sphere.</HelpString>
               <Image ID="sphere"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dish">
            <Macro>
               <Name>Dish</Name>
               <Command>^c^c_ai_dish</Command>
               <HelpString>Draws a mesh entity in the shape of the lower half of a sphere.</HelpString>
               <Image ID="dish"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dome">
            <Macro>
               <Name>Dome</Name>
               <Command>^c^c_ai_dome</Command>
               <HelpString>Draws a mesh entity in the shape of the upper half of a sphere.</HelpString>
               <Image ID="dome"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="torus">
            <Macro>
               <Name>Torus</Name>
               <Command>^c^c_ai_torus</Command>
               <HelpString>Draws a mesh torus.</HelpString>
               <Image ID="torus"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="3d_mesh">
            <Macro>
               <Name>Mesh</Name>
               <Command>^c^c_3d;_mesh</Command>
               <HelpString>Draws a mesh entity of evenly spaced lines between 4 corner points in 3 dimensions.</HelpString>
               <Image ID="3d_mesh"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pface">
            <Macro>
               <Name>Polyface Mesh</Name>
               <Command>^c^c_pface</Command>
               <HelpString>Creates a 3D polyface mesh with any number of vertices and faces. (PFACE)</HelpString>
               <Image ID="pface"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="3dface">
            <Macro>
               <Name>3D Face</Name>
               <Command>^c^c_3dface</Command>
               <HelpString>Creates one or more 3D faces each with 3 or 4 sides. (3DFACE)</HelpString>
               <Image ID="3dface"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="3dmesh">
            <Macro>
               <Name>Polygon Mesh</Name>
               <Command>^c^c_3dmesh</Command>
               <HelpString>Creates a 3D polygon mesh from an array of vertices. (3DMESH)</HelpString>
               <Image ID="3dmesh"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="convtomesh">
            <Macro>
               <Name>Convert to Mesh</Name>
               <Command>^c^c_convtomesh</Command>
               <HelpString>Converts 2D and 3D entities to meshes. (CONVTOMESH)</HelpString>
               <Image ID="convtomesh"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="revsurf">
            <Macro>
               <Name>Revolved Surface</Name>
               <Command>^c^c_revsurf</Command>
               <HelpString>Revolves a linear entity around a line to create a 3D mesh surface. (REVSURF)</HelpString>
               <Image ID="revsurf"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="rulesurf">
            <Macro>
               <Name>Ruled Surface</Name>
               <Command>^c^c_rulesurf</Command>
               <HelpString>Connects 2 linear entities, to create a 3D surface. (RULESURF)</HelpString>
               <Image ID="rulesurf"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="tabsurf">
            <Macro>
               <Name>Extruded Surface</Name>
               <Command>^c^c_tabsurf</Command>
               <HelpString>Projects an entity along a path to create a 3D surface. (TABSURF)</HelpString>
               <Image ID="tabsurf"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="edgesurf">
            <Macro>
               <Name>Coons Surface</Name>
               <Command>^c^c_edgesurf</Command>
               <HelpString>Creates a 3D Coons surface patch, between 4 lines that form a closed shape. (EDGESURF)</HelpString>
               <Image ID="edgesurf"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="3dpoly">
            <Macro>
               <Name>3D Polyline</Name>
               <Command>^c^c_3dpoly</Command>
               <HelpString>Draws a 3D polyline. (3DPOLY)</HelpString>
               <Image ID="3dpoly"/>
            </Macro>
         </MenuMacro>
