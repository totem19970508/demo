         </MenuMacro>
         <MenuMacro UID="url_update">
            <Macro>
               <Name>Update...</Name>
               <Command>$M=^c^c_url;https://www.bricsys.com/protected/download.do?utm_source=bricscad&amp;utm_medium=helpmenu&amp;utm_campaign=help_update</Command>
               <HelpString>Opens the Bricsys website to the BricsCAD download page.</HelpString>
               <Image ID="mcad_update"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="url_support">
            <Macro>
               <Name>Help...</Name>
               <Command>$M=^c^c_url;https://help.bricsys.com/?utm_source=bricscad&amp;utm_medium=helpmenu&amp;utm_campaign=help_support</Command>
               <HelpString>Opens the Bricsys Help Center.</HelpString>
               <Image ID="help"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="url_estore">
            <Macro>
               <Name>Store...</Name>
               <Command>$M=^c^c_url;https://www.bricsys.com/store/bricscad/?utm_source=bricscad&amp;utm_medium=helpmenu&amp;utm_campaign=help_store</Command>
               <HelpString>Opens the Bricsys Store.</HelpString>
               <Image ID="bricsys"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="appstore">
            <Macro>
               <Name>Application store</Name>
               <Command>$M=^c^c_url;https://www.bricsys.com/applications</Command>
               <HelpString>Opens the application store.</HelpString>
               <Image ID="bricsys"/>
            </Macro>
         </MenuMacro>
      </MacroGroup>
      <MacroGroup Name="Center entities">
         <MenuMacro UID="centerline">
            <Macro>
               <Name>Centerline</Name>
               <Command>^c^c_centerline</Command>
               <HelpString>Draws a new centerline. (CENTERLINE)</HelpString>
               <Image ID="centerline"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="centermark">
            <Macro>
               <Name>Center Mark</Name>
               <Command>^c^c_centermark</Command>
               <HelpString>Draws a new center mark. (CENTERMARK)</HelpString>
               <Image ID="centermark"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="centerreset">
            <Macro>
               <Name>Center Reset</Name>
               <Command>^c^c_centerreset</Command>
               <HelpString>Resets centerline and center mark entities. (CENTERRESET)</HelpString>
               <Image ID="centerreset"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="centerreassociate">
            <Macro>
               <Name>Center Reassociate</Name>
               <Command>^c^c_centerreassociate</Command>
               <HelpString>Reassociates a centerline entity with two selected lines, or a center mark with a circle or an arc. (CENTERREASSOCIATE)</HelpString>
               <Image ID="centerreassoc"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="centerdisassociate">
            <Macro>
               <Name>Center Disassociate</Name>
               <Command>^c^c_centerdisassociate</Command>
               <HelpString>Breaks the association of a centerline from other entities. (CENTERDISASSOCIATE)</HelpString>
               <Image ID="centerdisassoc"/>
            </Macro>
         </MenuMacro>
      </MacroGroup>
      <MacroGroup Name="Compare">
         <MenuMacro UID="compare_3d">
            <Macro>
               <Name>Compare</Name>
               <Command>^c^c_3DCOMPARE</Command>
               <HelpString>Opens the Compare two models dialog to compare solid and surface geometry between two drawing files. (3DCOMPARE)</HelpString>
               <Image ID="acis_3dcompare"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="diff_left_viewport">
            <Macro>
               <Name>Left Viewport</Name>
               <Command>'_setvar;3DCOMPAREMODE;$M=$(if,$(&gt;,0,$(getvar,3DCOMPAREMODE)),1,$(xor,$(getvar,3DCOMPAREMODE),1))</Command>
               <HelpString>Toggles the differences in the left viewport on/off.</HelpString>
               <Image ID="acis_leftviewport"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="diff_right_viewport">
            <Macro>
               <Name>Right Viewport</Name>
               <Command>'_setvar;3DCOMPAREMODE;$M=$(if,$(&gt;,0,$(getvar,3DCOMPAREMODE)),2,$(xor,$(getvar,3DCOMPAREMODE),2))</Command>
               <HelpString>Toggles the differences in the right viewport on/off.</HelpString>
               <Image ID="acis_rightviewport"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="single_diff">
            <Macro>
               <Name>Single Viewport</Name>
               <Command>'_setvar;3DCOMPAREMODE;$M=$(if,$(&gt;,0,$(getvar,3DCOMPAREMODE)),4,$(xor,$(getvar,3DCOMPAREMODE),4))</Command>
               <HelpString>Shows differences in a single viewport.</HelpString>
               <Image ID="acis_singleviewport"/>
            </Macro>
         </MenuMacro>
      </MacroGroup>
      <MacroGroup Name="Context">
         <MenuMacro UID="grips_menu">
            <Macro>
               <Name>Grips Menu</Name>
               <Command>$p0=GRIPS $p0=*</Command>
               <HelpString>Displays the Grips context menu.</HelpString>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="snap_menu">
            <Macro>
               <Name>Snap Menu</Name>
               <Command>$p0=SNAP $p0=*</Command>
               <HelpString>Displays the Snap context menu.</HelpString>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="edit_menu">
            <Macro>
               <Name>Edit Menu</Name>
               <Command>$p0=CMEDIT $p0=*</Command>
               <HelpString>Displays the Edit context menu.</HelpString>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="enter">
            <Macro>
               <Name>Enter</Name>
               <Command>;</Command>
               <HelpString>Completes a command, accepts command values, and cycles grip modes.</HelpString>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="cancel">
            <Macro>
               <Name>Cancel</Name>
               <Command>^c</Command>
               <HelpString>Cancels the command.</HelpString>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="repeat">
            <Macro>
               <Name>Repeat</Name>
               <Command>^c^c;</Command>
               <HelpString>Repeats the previous command.</HelpString>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="grip_move">
            <Macro>
               <Name>Move</Name>
               <Command>_move</Command>
               <HelpString>Moves entities. (MOVE)</HelpString>
               <Image ID="move"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="grip_mirror">
            <Macro>
               <Name>Mirror</Name>
               <Command>_mirror</Command>
               <HelpString>Mirrors entities along a line. (MIRROR)</HelpString>
               <Image ID="mirror"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="grip_rotate">
            <Macro>
               <Name>Rotate</Name>
               <Command>_rotate</Command>
               <HelpString>Rotates entities around a point. (ROTATE)</HelpString>
               <Image ID="rotate"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="grip_scale">
            <Macro>
               <Name>Scale</Name>
               <Command>_scale</Command>
               <HelpString>Resizes 2D and 3D entities, without changing the aspect ratio. (SCALE)</HelpString>
               <Image ID="scale"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="grip_stretch">
            <Macro>
               <Name>Stretch</Name>
               <Command>_stretch</Command>
               <HelpString>Stretches 2D entities and does not break connections. (STRETCH)</HelpString>
               <Image ID="stretch"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="grip_base">
            <Macro>
               <Name>Base Point</Name>
               <Command>_base</Command>
               <HelpString>Sets the base insertion point. (BASE)</HelpString>
               <Image ID="base"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="grip_copy">
            <Macro>
               <Name>Copy</Name>
               <Command>_copy</Command>
               <HelpString>Copies entities. (COPY)</HelpString>
               <Image ID="copy"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="grip_exit">
            <Macro>
               <Name>Exit</Name>
               <Command>_exit</Command>
               <HelpString>Cancels grip edit mode and returns to the Command line. (EXIT)</HelpString>
            </Macro>
         </MenuMacro>
      </MacroGroup>
      
      <MacroGroup Name="Design Intent">
         <MenuMacro UID="di_tangent">
            <Macro>
               <Name>Tangent surfaces</Name>
               <Command>'_setvar;DMRECOGNIZE;$M=$(if,$(&gt;,0,$(getvar,DMRECOGNIZE)),1,$(xor,$(getvar,DMRECOGNIZE),0x0001))</Command>
               <HelpString>Recognizes and maintains tangent surfaces: planes, cylinders and cones.</HelpString>
               <Image ID="di_tangent"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="di_coincident">
            <Macro>
               <Name>Coincident planes</Name>
               <Command>'_setvar;DMRECOGNIZE;$M=$(if,$(&gt;,0,$(getvar,DMRECOGNIZE)),2,$(xor,$(getvar,DMRECOGNIZE),0x0002))</Command>
               <HelpString>Recognizes and maintains coincident planes.</HelpString>
               <Image ID="di_coincident"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="di_parallel">
            <Macro>
               <Name>Parallel planes</Name>
               <Command>'_setvar;DMRECOGNIZE;$M=$(if,$(&gt;,0,$(getvar,DMRECOGNIZE)),4,$(xor,$(getvar,DMRECOGNIZE),0x0004))</Command>
               <HelpString>Recognizes and maintains parallel planes.</HelpString>
               <Image ID="di_parallel"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="di_perpendicular">
            <Macro>
               <Name>Perpendicular planes</Name>
               <Command>'_setvar;DMRECOGNIZE;$M=$(if,$(&gt;,0,$(getvar,DMRECOGNIZE)),8,$(xor,$(getvar,DMRECOGNIZE),0x0008))</Command>
               <HelpString>Recognizes and maintains perpendicular planes.</HelpString>
               <Image ID="di_perpendicular"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="di_perpendicular_cylinders">
            <Macro>
               <Name>Perpendicular Cylinders</Name>
               <Command>'_setvar;DMRECOGNIZE;$M=$(if,$(&gt;,0,$(getvar,DMRECOGNIZE)),16,$(xor,$(getvar,DMRECOGNIZE),0x0010))</Command>
               <HelpString>Recognizes and maintains cylinders perpendicular to planes.</HelpString>
               <Image ID="di_perpendicular_cylinders"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="di_coaxial">
            <Macro>
               <Name>Coaxial surfaces</Name>
               <Command>'_setvar;DMRECOGNIZE;$M=$(if,$(&gt;,0,$(getvar,DMRECOGNIZE)),32,$(xor,$(getvar,DMRECOGNIZE),0x0020))</Command>
               <HelpString>Recognizes and maintains coaxial surfaces.</HelpString>
               <Image ID="di_coaxial"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="di_equal_radius">
            <Macro>
               <Name>Equal radius</Name>
               <Command>'_setvar;DMRECOGNIZE;$M=$(if,$(&gt;,0,$(getvar,DMRECOGNIZE)),64,$(xor,$(getvar,DMRECOGNIZE),0x0040))</Command>
               <HelpString>Recognizes and maintains cylinders and spheres of equal radius.</HelpString>
               <Image ID="di_equal_radius"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="di_vertex_topology">
            <Macro>
               <Name>Vertices between 4 or more faces</Name>
               <Command>'_setvar;DMRECOGNIZE;$M=$(if,$(&gt;,0,$(getvar,DMRECOGNIZE)),128,$(xor,$(getvar,DMRECOGNIZE),0x0080))</Command>
               <HelpString>Prevents the split of vertices between 4 or more faces.</HelpString>
               <Image ID="di_vertex_topology"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="di_imprinted_edges">
            <Macro>
               <Name>Edges between coincident faces</Name>
               <Command>'_setvar;DMRECOGNIZE;$M=$(if,$(&gt;,0,$(getvar,DMRECOGNIZE)),256,$(xor,$(getvar,DMRECOGNIZE),0x0100))</Command>
               <HelpString>Prevents the split of vertices between edges and coincident faces.</HelpString>
               <Image ID="di_imprinted_edges"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="di_none">
            <Macro>
               <Name>Switch off</Name>
               <Command>'_setvar;DMRECOGNIZE;$M=$(*,-1,$(getvar,DMRECOGNIZE))</Command>
               <HelpString>Toggles Design Intent on/off.</HelpString>
               <Image ID="erase"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="userparameter">
            <Macro>
               <Name>User Parameter</Name>
               <Command>^c^c_-parameters;n;;;^c^c$M=$(if,$(=,0,$(getvar,"MBSTATE")),_mechanicalbrowseropen)</Command>
               <HelpString>Creates a new, user parameter.</HelpString>
               <Image ID="parameters"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="suppress">
            <Macro>
               <Name>Suppress</Name>
               <Command>^c^c_suppress</Command>
               <HelpString>Suppresses the display of entities. (SUPPRESS)</HelpString>
               <Image ID="suppress_new"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="designtable_file">
            <Macro>
               <Name>Design Table from File</Name>
               <Command>^c^c_designtable;_f</Command>
               <HelpString>Creates a design table from a file.</HelpString>
               <Image ID="designtable_file"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="designtable_empty">
            <Macro>
               <Name>Empty Design Table</Name>
               <Command>^c^c_designtable;_e</Command>
               <HelpString>Creates an empty design table.</HelpString>
               <Image ID="designtable_empty"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="cleanunusedvar">
            <Macro>
               <Name>Delete Unused Parameters</Name>
               <Command>^c^c_cleanunusedvariables</Command>
               <HelpString>Removes all unused parameters from the drawing. (CLEANUNUSEDVARIABLES)</HelpString>
               <Image ID="purge"/>
            </Macro>
         </MenuMacro>
      </MacroGroup>
      <MacroGroup Name="Dimensions">
         <MenuMacro UID="dim">
            <Macro>
               <Name>Dimension</Name>
               <Command>^c^c_dim</Command>
               <HelpString>Draws multiple dimension types in a single workflow and automatically detects the correct dimension type for each entity. (DIM)</HelpString>
               <Image ID="dim"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bimdimension">
            <Macro>
               <Name>Bim Dimension</Name>
               <Command>^c^c_bimdimension</Command>
               <HelpString>Draws dimensions on BIM entities, in a viewport, semi-automatically. (BIMDIMENSION)</HelpString>
               <Image ID="bimdimension"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dimlinear">
            <Macro>
               <Name>Linear Dimension</Name>
               <Command>^c^c_dimlinear</Command>
               <HelpString>Draws a horizontal or vertical dimension. (DIMLINEAR)</HelpString>
               <Image ID="dimlinear"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dimaligned">
            <Macro>
               <Name>Aligned Dimension</Name>
               <Command>^c^c_dimaligned</Command>
               <HelpString>Draws an aligned dimension - parallel to the start and end points. (DIMALIGNED)</HelpString>
               <Image ID="dimaligned"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dimlinear_rotated">
            <Macro>
               <Name>Rotated</Name>
               <Command>^c^c_dimlinear;\\_rotated</Command>
               <HelpString>Draws a linear dimension, at an angle.</HelpString>
               <Image ID="dimlinear_rotated"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dimangular">
            <Macro>
               <Name>Angular</Name>
               <Command>^c^c_dimangular</Command>
               <HelpString>Draws an angle dimension. (DIMANGULAR)</HelpString>
               <Image ID="dimangular"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dimarc">
            <Macro>
               <Name>Arc</Name>
               <Command>^c^c_dimarc</Command>
               <HelpString>Draws an arc length dimension. (DIMARC)</HelpString>
               <Image ID="dimarc"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dimcenter">
            <Macro>
               <Name>Dimcenter</Name>
               <Command>^c^c_dimcenter</Command>
               <HelpString>Draws a center mark at the center of a circle, arc or polyarc - see the CENTERMARK command to create associative center marks. (DIMCENTER)</HelpString>
               <Image ID="dimcenter"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="qdim">
            <Macro>
               <Name>Quick Dimension</Name>
               <Command>^c^c_qdim</Command>
               <HelpString>Creates a series of dimensions from selected entities. (QDIM)</HelpString>
               <Image ID="qdim"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="aidimprec0">
            <Macro>
               <Name>0</Name>
