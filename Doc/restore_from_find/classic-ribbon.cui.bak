               <Image ID="find"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="rename">
            <Macro>
               <Name>Rename...</Name>
               <Command>^c^c_rename</Command>
               <HelpString>Renames named entities. (RENAME)</HelpString>
               <Image ID="regen"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="hideobjects">
            <Macro>
               <Name>Hide Entities</Name>
               <Command>^c^c_hideobjects</Command>
               <HelpString>Hides selected entities. (HIDEOBJECTS)</HelpString>
               <Image ID="hide_objects"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="isolateobjects">
            <Macro>
               <Name>Isolate Entities</Name>
               <Command>^c^c_isolateobjects</Command>
               <HelpString>Hides all but the currently select entities. (ISOLATEOBJECTS)</HelpString>
               <Image ID="isolate_objects"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="unisolateobjects">
            <Macro>
               <Name>Show Entities</Name>
               <Command>^c^c_unisolateobjects</Command>
               <HelpString>Shows all previously, temporarily hidden entities. (UNISOLATEOBJECTS)</HelpString>
               <Image ID="unisolate_objects"/>
            </Macro>
         </MenuMacro>
