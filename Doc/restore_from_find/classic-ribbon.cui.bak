   </Header>
   <MenuGroup Name="BRICSCAD">
      <MacroGroup Name="2D Constraints">
         <MenuMacro UID="gc_coincident">
            <Macro>
               <Name>Coincident</Name>
               <Command>^c^c_gccoincident</Command>
               <HelpString>Creates a coincident geometric constraint between two, 2D entities. (GCCOINCIDENT)</HelpString>
               <Image ID="gc_coincident"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="gc_collinear">
            <Macro>
               <Name>Collinear</Name>
               <Command>^c^c_gccollinear</Command>
               <HelpString>Creates a colinear constraint to ensure two or more 2D, linear entities remain colinear. (GCCOLINEAR)</HelpString>
               <Image ID="gc_collinear"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="gc_concentric">
            <Macro>
               <Name>Concentric</Name>
               <Command>^c^c_gcconcentric</Command>
               <HelpString>Creates a concentric constraint to ensure two, 2D circular or elliptical entities remain concentric. (GCCONCENTRIC)</HelpString>
               <Image ID="gc_concentric"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="gc_parallel">
            <Macro>
               <Name>Parallel</Name>
               <Command>^c^c_gcparallel</Command>
               <HelpString>Creates a parallel constraint between two, 2D entities. (GCPARALLEL)</HelpString>
               <Image ID="gc_parallel"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="gc_perpendicular">
            <Macro>
               <Name>Perpendicular</Name>
               <Command>^c^c_gcperpendicular</Command>
               <HelpString>Creates a perpendicular constraint to ensure two, 2D, linear entities maintain a right angle to each other.  (GCPERPENDICULAR)</HelpString>
               <Image ID="gc_perpendicular"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="gc_tangent">
            <Macro>
               <Name>Tangent</Name>
               <Command>^c^c_gctangent</Command>
               <HelpString>Creates a tangent constraint to ensure a 2D, curved entity remains tangent to another 2D curved or linear entity.  (GCTANGENT)</HelpString>
               <Image ID="gc_tangent"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="gc_horizontal">
            <Macro>
               <Name LocalizationId="gc_horizontal">Horizontal</Name>
               <Command>^c^c_gchorizontal</Command>
               <HelpString>Creates a horizontal constraint to ensure that a 2D linear entity or pair of points, remains parallel to the x-axis. (GCHORIZONTAL)</HelpString>
               <Image ID="gc_horizontal"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="gc_vertical">
            <Macro>
               <Name LocalizationId="gc_vertical">Vertical</Name>
               <Command>^c^c_gcvertical</Command>
               <HelpString>Creates a vertical constraint to ensure that a 2D linear entity or pair of points, remains parallel to the y-axis. (GCVERTICAL)</HelpString>
               <Image ID="gc_vertical"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="gc_smooth">
            <Macro>
               <Name>Smooth</Name>
               <Command>^c^c_gcsmooth</Command>
               <HelpString>Creates a smooth constraint to ensure two splines maintain fluid geometric continuity between them. (GCSMOOTH)</HelpString>
               <Image ID="gc_smooth"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="gc_symmetric">
            <Macro>
               <Name>Symmetric</Name>
               <Command>^c^c_gcsymmetric</Command>
               <HelpString>Creates a symmetric constraint to ensure two, 2D entities remain symmetric with respect to a line. (GCSYMMETRIC)</HelpString>
               <Image ID="gc_symmetric"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="gc_equal">
            <Macro>
               <Name>Equal</Name>
               <Command>^c^c_gcequal</Command>
               <HelpString>Creates an equal constraint to ensure 2D, circular entities maintain equal radii, or 2D linear entities maintain equal lengths. (GCEQUAL) </HelpString>
               <Image ID="gc_equal"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="gc_fix">
            <Macro>
               <Name>Fix</Name>
               <Command>^c^c_gcfix</Command>
               <HelpString>Creates a fixed constraint on a point or entity to maintain its position in the drawing. (GCFIX)</HelpString>
               <Image ID="gc_fix"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dc_aligned">
            <Macro>
               <Name>Aligned</Name>
               <Command>^c^c_dcaligned</Command>
               <HelpString>Constrains the distance between two, 2D entities. (DCALIGNED)</HelpString>
               <Image ID="dc_aligned"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dc_horizontal">
            <Macro>
               <Name LocalizationId="dc_horizontal">Horizontal</Name>
               <Command>^c^c_dchorizontal</Command>
               <HelpString>Horizontally constrains the distance between two points, or the length of a single, 2D entity. (DCHORIZONTAL)</HelpString>
               <Image ID="dc_horizontal"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dc_vertical">
            <Macro>
               <Name LocalizationId="dc_vertical">Vertical</Name>
               <Command>^c^c_dcvertical</Command>
               <HelpString>Vertically constrains the distance between two points, or the length of a single, 2D entity. (DCVERTICAL)</HelpString>
               <Image ID="dc_vertical"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dc_linear">
            <Macro>
               <Name>Linear</Name>
               <Command>^c^c_dclinear</Command>
               <HelpString>Constrains the distance between two points, or the length of a single, 2D entity, horizontally or vertically. (DCLINEAR)</HelpString>
               <Image ID="dc_linear"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dc_angular">
            <Macro>
               <Name>Angular</Name>
               <Command>^c^c_dcangular</Command>
               <HelpString>Constrains the angle between two lines or straight polyline segments; also constrains the angles of arcs, polyline arcs, and any three constraint points. (DCANGULAR)</HelpString>
               <Image ID="dc_angular"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dc_radius">
            <Macro>
               <Name>Radius</Name>
               <Command>^c^c_dcradius</Command>
               <HelpString>Constrains the radius of circles, arcs, or polyline arc segments. (DCRADIUS)</HelpString>
               <Image ID="dc_radius"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dc_diameter">
            <Macro>
               <Name>Diameter</Name>
               <Command>^c^c_dcdiameter</Command>
               <HelpString>Constrains the diameter of circles, arcs, or polyline arc segments. (DCDIAMETER)</HelpString>
               <Image ID="dc_diameter"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dc_convert">
            <Macro>
               <Name>Convert</Name>
               <Command>^c^c_dcconvert</Command>
               <HelpString>Converts associative dimensions into 2D constraints. (DCCONVERT)</HelpString>
               <Image ID="dc_convert"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="show_hide_constraintbar">
            <Macro>
               <Name>Show/Hide Geometric Constraint</Name>
               <Command>^c^c_constraintbar</Command>
               <HelpString>Toggles the display of 2D geometric constraints on/off, for individual entities. (CONSTRAINTBAR)</HelpString>
               <Image ID="gc_show_hide"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="show_all_constraintbar">
            <Macro>
               <Name>Show All Geometric Constraints</Name>
               <Command>^c^c_selgrips;;_constraintbar;_ALL;;^P(if(ssget "P")(command "_S"))(princ)</Command>
               <HelpString>Shows all 2D geometric constraints.</HelpString>
               <Image ID="gc_show"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="hide_all_constraintbar">
            <Macro>
               <Name>Hide All Geometric Constraints</Name>
               <Command>^c^c_selgrips;;_constraintbar;_ALL;;^P(if(ssget "P")(command "_H"))(princ)</Command>
               <HelpString>Hides all 2D geometric constraints.</HelpString>
               <Image ID="gc_hide"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="show_hide_dcdisplay">
            <Macro>
               <Name>Show/Hide Dimensional Constraint</Name>
               <Command>^c^c_dcdisplay</Command>
               <HelpString>Toggles the display of 2D dimensional constraints on/off, for individual entities. (CONSTRAINTBAR)</HelpString>
               <Image ID="dc_show_hide"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="show_all_dcdisplay">
            <Macro>
               <Name>Show All Dimensional Constraints</Name>
               <Command>^c^c_selgrips;;_dcdisplay;_ALL;;^P(if(ssget "P")(command "_S"))(princ)</Command>
               <HelpString>Shows all 2D dimensional constraints.</HelpString>
               <Image ID="dc_show"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="hide_all_dcdisplay">
            <Macro>
               <Name>Hide All Dimensional Constraints</Name>
               <Command>^c^c_selgrips;;_dcdisplay;_ALL;;^P(if(ssget "P")(command "_H"))(princ)</Command>
               <HelpString>Hides all 2D dimensional constraints.</HelpString>
               <Image ID="dc_hide"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="delconstraint">
            <Macro>
               <Name>Delete 2D Constraints</Name>
               <Command>^c^c_delconstraint</Command>
               <HelpString>Deletes all 2D constraints for an entity. (DELCONSTRAINT)</HelpString>
               <Image ID="erase"/>
            </Macro>
         </MenuMacro>
      </MacroGroup>
      <MacroGroup Name="2D Parametric Block">
         <MenuMacro UID="pb_parametricblock">
            <Macro>
               <Name>Parametric Block</Name>
               <Image ID="pb_create"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pb_autoconstrain">
            <Macro>
               <Name>Autoconstrain</Name>
               <Command>^c^c_autoconstrain</Command>
               <HelpString>Automatically constrains 2D geometry. (AUTOCONSTRAIN)</HelpString>
               <Image ID="pb_autoconstrain"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pb_guidecurves">
            <Macro>
               <Name>Reference curves</Name>
               <Command>^c^c_referencecurves</Command>
               <HelpString>Creates reference geometry that automatically aligns a block. (REFERENCECURVES)</HelpString>
               <Image ID="pb_guidecurves"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pb_flipline">
            <Macro>
               <Name>Flipline</Name>
               <Command>^c^c_flipline</Command>
               <HelpString>Creates an operation to flip entities. (PARAMETRICFLIP)</HelpString>
               <Image ID="pb_flipline"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pb_stretch">
            <Macro>
               <Name>Stretch</Name>
               <Command>^c^c_parametricstretch</Command>
               <HelpString>Creates an operation to stretch entities. (PARAMETRICSTRETCH)</HelpString>
               <Image ID="pb_stretch"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pb_move">
            <Macro>
               <Name>Move</Name>
               <Command>^c^c_parametricmove</Command>
               <HelpString>Creates an operation to move entities. (PARAMETRICMOVE)</HelpString>
               <Image ID="pb_move"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pb_scale">
            <Macro>
               <Name>Scale</Name>
               <Command>^c^c_parametricscale</Command>
               <HelpString>Creates an operation to scale entities. (PARAMETRICSCALE)</HelpString>
               <Image ID="pb_scale"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pb_rotate">
            <Macro>
               <Name>Rotate</Name>
               <Command>^c^c_parametricrotate</Command>
               <HelpString>Creates an operation to rotate entities. (PARAMETRICROTATE)</HelpString>
               <Image ID="pb_rotate"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pb_offset">
            <Macro>
               <Name>Offset</Name>
               <Command>^c^c_parametricoffset</Command>
               <HelpString>Creates an operation to offset entities. (PARAMETRICOFFSET)</HelpString>
               <Image ID="pb_offset"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pb_visibility">
            <Macro>
               <Name>Visibility</Name>
               <Command>$M=$(if,$(and,$(&gt;,$(getvar,VPSTATE),0)),^c^c_visibilitystatespanelclose,^c^c_visibilitystatespanelopen)</Command>
               <HelpString>Toggles the Visibility States Panel on/off.</HelpString>
               <Image ID="pb_visibility"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="show_hide_pbdisplay">
            <Macro>
               <Name>Show/Hide Parametric Operations</Name>
               <Command>^c^c_pblockoperationsdisplay</Command>
               <HelpString>Toggles the display of parametric operations on/off, for individual entities.</HelpString>
               <Image ID="pb_show_hide"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="show_all_pbdisplay">
            <Macro>
               <Name>Show All Parametric Operations</Name>
               <Command>^c^c_pblockoperationsdisplay;_ALL;;^P(if(ssget "P")(command "_S"))(princ)</Command>
               <HelpString>Shows all parametric operations.</HelpString>
               <Image ID="pb_show"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="hide_all_pbdisplay">
            <Macro>
               <Name>Hide All Parametric Operations</Name>
               <Command>^c^c_pblockoperationsdisplay;_ALL;;^P(if(ssget "P")(command "_H"))(princ)</Command>
               <HelpString>Hides all parametric operations.</HelpString>
               <Image ID="pb_hide"/>
            </Macro>
         </MenuMacro>
      </MacroGroup>
      <MacroGroup Name="3D Entity Snaps">
         <MenuMacro UID="3dsnap_vertex">
            <Macro>
               <Name>Snap to Vertex</Name>
               <Command>_zvertex</Command>
               <HelpString>Snaps to the closest vertex of a 3D entity. (ZVERTEX)</HelpString>
               <Image ID="3dsnap_vertex"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="3dsnap_midpoint">
            <Macro>
               <Name>Snap to Midpoint</Name>
               <Command>_zmidpoint</Command>
               <HelpString>Snaps to the midpoint of an edge of 3D entity. (ZMIDPOINT)</HelpString>
               <Image ID="3dsnap_midpoint"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="3dsnap_center">
            <Macro>
               <Name>Snap to Center of a face</Name>
               <Command>_zcenter</Command>
               <HelpString>Snaps to the center of a face or 3D polyline. (ZCENTER)</HelpString>
               <Image ID="3dsnap_center"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="3dsnap_perpendicular">
            <Macro>
               <Name>Snap to Perpendicular on a face</Name>
               <Command>_zperpendicular</Command>
               <HelpString>Snaps to a point perpendicular to a face, 3D polyline or spline. (ZPERPENDICULAR)</HelpString>
               <Image ID="3dsnap_perpendicular"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="3dsnap_nearest">
            <Macro>
               <Name>Snap to Nearest</Name>
               <Command>_znearest</Command>
               <HelpString>Snaps to the nearest point on a face, 3D polylne or spline. (ZNEAREST)</HelpString>
               <Image ID="3dsnap_nearest"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="3dsnap_knot">
            <Macro>
               <Name>Snap to Knot</Name>
               <Command>_zknot</Command>
               <HelpString>Snaps to the knot of a spline. (ZKNOT)</HelpString>
               <Image ID="3dsnap_knot"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="3dsnap_intersection">
            <Macro>
               <Name>Snap to Intersection</Name>
               <Command>_zintersection</Command>
               <HelpString>Snaps to the intersection between faces and curves. (ZINTERSECTION)</HelpString>
               <Image ID="3dsnap_intersection"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="3dsnap_pointcloud">
            <Macro>
               <Name>Snap to Point Cloud</Name>
               <Command>_pcnearest</Command>
               <HelpString>Snaps to nearest point of a point cloud. (PCNEAREST)</HelpString>
               <Image ID="3dsnap_pointcloud"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="3dsnap_none">
            <Macro>
               <Name>Clear 3D Entity Snaps</Name>
               <Command>_znone</Command>
               <HelpString>Turns 3D entity snaps off. (ZNONE)</HelpString>
               <Image ID="osnap_none"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="3dsnap_t">
            <Macro>
               <Name>3D Entity snap toggle</Name>
               <Command>'_-3dosnap;_t</Command>
               <HelpString>Toggles 3D entity snaps on/off.</HelpString>
               <Image ID="osnap"/>
            </Macro>
         </MenuMacro>
      </MacroGroup>
      <MacroGroup Name="3D Solid Editing">
