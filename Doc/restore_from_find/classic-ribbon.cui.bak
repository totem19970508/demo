      <MacroGroup Name="Inquiry">
         <MenuMacro UID="dist">
            <Macro>
               <Name>Distance</Name>
               <Command>'_dist</Command>
               <HelpString>Finds the distance between two points. (DIST)</HelpString>
               <Image ID="dist"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="nearestdistance">
            <Macro>
               <Name>Nearest Distance</Name>
               <Command>'_NEARESTDISTANCE;$M=$(if,$(&gt;,0,$(getvar,NEARESTDISTANCE)),1,$(xor,$(getvar,NEARESTDISTANCE),1))</Command>
               <HelpString>Toggles the display of the Nearest Distance field on/off.</HelpString>
               <Image ID="nearestdistance"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="area">
            <Macro>
               <Name>Area</Name>
               <Command>^c^c_area</Command>
               <HelpString>Finds the area inside a closed entity. (AREA)</HelpString>
               <Image ID="area"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="massprop">
            <Macro>
               <Name>Mass Properties</Name>
               <Command>^c^c_massprop</Command>
               <HelpString>Calculates and displays the mass properties of regions or solids. (MASSPROP)</HelpString>
               <Image ID="massprop"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="id">
            <Macro>
               <Name>ID Coordinates</Name>
               <Command>^c^c_id</Command>
               <HelpString>Shows the X, Y, and Z coordinates of a point in the Command line. (ID)</HelpString>
               <Image ID="id"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="list">
            <Macro>
               <Name>List Entity Info</Name>
               <Command>^c^c_list</Command>
               <HelpString>Lists information about an entity/entities in the Prompt History dialog. (LIST)</HelpString>
               <Image ID="list"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="status">
            <Macro>
               <Name>Drawing Status</Name>
               <Command>^c^c_status</Command>
               <HelpString>Shows the drawing status in the Prompt History dialog. (STATUS)</HelpString>
               <Image ID="status"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="time">
            <Macro>
               <Name>Time Variables</Name>
               <Command>^c^c_time</Command>
               <HelpString>Reports the date and time a drawing was created, last updated, and the time spent on edits, in the Command line. (TIME)</HelpString>
               <Image ID="time"/>
            </Macro>
         </MenuMacro>
      </MacroGroup>
