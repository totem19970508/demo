         <MenuMacro UID="stylesmanager">
            <Macro>
               <Name>Plotstyle Manager...</Name>
               <Command>^c^c_stylesmanager</Command>
               <HelpString>Opens the plotstyles folder, to create and edit plot style files. (STYLESMANAGER)</HelpString>
               <Image ID="plotstylemanager"/>
            </Macro>
         </MenuMacro>
         
         
         <MenuMacro UID="spell">
            <Macro>
               <Name>Check Spelling</Name>
               <Command>^c^c_spell</Command>
               <HelpString>Opens the Spell Checking dialog, to check the drawing for spelling errors. (SPELL)</HelpString>
               <Image ID="spell"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="mail">
            <Macro>
               <Name>Send Mail...</Name>
               <Command>^c^c_mail</Command>
               <HelpString>Opens the default email client and creates a new email, with the current drawing attached. (MAIL)</HelpString>
               <Image ID="mail"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="etransmit">
            <Macro>
               <Name>eTransmit/Upload...</Name>
               <Command>^c^c_etransmit</Command>
               <HelpString>Opens the Drawing Explorer dialog, to view and modify all dependencies in the current drawing. (ETRANSMIT)</HelpString>
               <Image ID="etransmit"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="login">
            <Macro>
               <Name>...</Name>
               <Command>$M=$(if,$(getvar,LOGGEDINSTATUS),^c^c_-logout,^c^c_-login)</Command>
               <HelpString>Logs in/out of a Bricsys account.</HelpString>
               <Image ID="user"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="analytics">
            <Macro>
               <Name>Manage User Data...</Name>
               <Command>^c^c_analytics</Command>
               <HelpString>Manages how user data is shared.</HelpString>
               <Image ID="manage_usage_data"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dwgprops">
            <Macro>
               <Name>Drawing Properties...</Name>
               <Command>^c^c_dwgprops</Command>
               <HelpString>Opens the Drawing Properties dialog, to view and modify drawing properties. (DWGPROPS)</HelpString>
               <Image ID="panel_properties"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="securityoptions">
            <Macro>
               <Name>Security Options...</Name>
               <Command>^c^c_securityoptions</Command>
               <HelpString>Opens the Security Options dialog, to set a password to protect a drawing from unauthorized access. (SECURITYOPTIONS)</HelpString>
               <Image ID="toggle_lock"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="mru">
            <Macro>
               <Name>[Recent Files]</Name>
               <HelpString>Opens a drawing.</HelpString>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="quit">
            <Macro>
               <Name>Exit</Name>
               <Command>^c^c_quit</Command>
               <HelpString>Closes all open drawings and exits BricsCAD; offers the opportunity to save unsaved drawings. (QUIT)</HelpString>
               <Image ID="quit"/>
            </Macro>
         </MenuMacro>
      </MacroGroup>
      <MacroGroup Name="Help">
         <MenuMacro UID="about">
            <Macro>
               <Name>About BricsCAD...</Name>
               <Command>'_about</Command>
