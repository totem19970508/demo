            </Macro>
         </MenuMacro>
         <MenuMacro UID="wvtile">
            <Macro>
               <Name>Tile Vertically</Name>
               <Command>'_wvtile</Command>
               <HelpString>Arranges windows as vertical tiles. (WVTILE)</HelpString>
               <Image ID="wvtile"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="wnext">
            <Macro>
               <Name>Next</Name>
               <Command>'_wnext</Command>
               <HelpString>Selects the next window. (WNEXT)</HelpString>
               <Image ID="find_next"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="wprev">
            <Macro>
               <Name>Previous</Name>
               <Command>'_wprev</Command>
               <HelpString>Selects the previously open window. (WPREV)</HelpString>
