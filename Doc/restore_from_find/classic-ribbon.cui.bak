            </Macro>
         </MenuMacro>
         <MenuMacro UID="setlicenselevelbim">
            <Macro>
               <Name>Run as BricsCAD BIM</Name>
               <Command>^c^c_setlicenselevel;_bricscad;_bim;</Command>
               <HelpString>Runs BricsCAD at the BricsCAD BIM license level, if the license is available. A restart is required.</HelpString>
               <Image ID="license_bim"/>
