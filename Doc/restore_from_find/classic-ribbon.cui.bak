               <Image ID="leicaconvert"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="gisimport">
            <Macro>
               <Name>GIS Import</Name>
               <Command>^c^c_gisImport</Command>
               <HelpString>Imports spatial and attribute data from an ESRI SHP file. (GISIMPORT)</HelpString>
               <Image ID="gisimport"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="gisexport">
            <Macro>
               <Name>GIS Export</Name>
               <Command>^c^c_gisExport</Command>
               <HelpString>Exports spatial and attribute data in an ESRI SHP file. (GISEXPORT)</HelpString>
               <Image ID="gisexport"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="addsurfacelabels">
            <Macro>
               <Name>Add Surface Labels</Name>
               <Command>^c^c_addSurfaceLabels</Command>
               <HelpString>Adds spot elevation labels, slope labels or contour labels on a surface. (ADDSURFACELABELS)</HelpString>
               <Image ID="addsurfacelabels"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="add_linecurve_labels">
            <Macro>
               <Name>Add Line and Curve Labels</Name>
               <Command>^c^c_addLineCurveLabels</Command>
               <HelpString>Adds line and curve labels to lines, arcs, strings, polylines or 3D polylines. (ADDLINECURVELABELS)</HelpString>
               <Image ID="add_linecurve_labels"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="export_linecurve_labels">
            <Macro>
               <Name>Export Line and Curve Labels</Name>
               <Command>^c^c_exportLineCurveLabels</Command>
               <HelpString>Exports line and curve labels to a csv file. (EXPORTLINECURVELABELS)</HelpString>
               <Image ID="export_linecurve_labels"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bearing_distance">
            <Macro>
               <Name>Bearing and Distance</Name>
               <Command>'_BD</Command>
               <HelpString>Specifies a point location at a bearing and distance from a known point. ('BD)</HelpString>
               <Image ID="bearing_distance"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="azimuth_distance">
            <Macro>
               <Name>Azimuth and Distance</Name>
               <Command>'_ZD</Command>
               <HelpString>Specifies a point location at an azimuth and distance from a known point. ('ZD)</HelpString>
               <Image ID="azimuth_distance"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="station_offset">
            <Macro>
               <Name>Station and Offset</Name>
               <Command>'_SO</Command>
               <HelpString>Specifies a point location at a station and an offset from an alignment. ('SO)</HelpString>
               <Image ID="station_offset"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="point_number">
            <Macro>
               <Name>Point Number</Name>
               <Command>'_PN</Command>
               <HelpString>Specifies a point location using a civil point number. ('PN)</HelpString>
               <Image ID="point_number"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="point_object">
            <Macro>
               <Name>Point Object</Name>
               <Command>'_PO</Command>
               <HelpString>Specifies a point location by picking an existing civil point. ('PO)</HelpString>
               <Image ID="point_object"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="angle_distance">
            <Macro>
               <Name>Angle and Distance</Name>
               <Command>'_ANGD</Command>
               <HelpString>Specifies a point location at an angle and distance from a known point and direction. ('ANGD)</HelpString>
               <Image ID="angle_distance"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="deflection_distance">
            <Macro>
               <Name>Deflection and Distance</Name>
               <Command>'_DD</Command>
               <HelpString>Specifies a point location at an angle and distance from a known point and previous direction. ('DD)</HelpString>
               <Image ID="deflection_distance"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bimblocklevelofdetail">
            <Macro>
               <Name>Block Level of Detail</Name>
               <Command>'BLOCKLEVELOFDETAIL;$M=$(xor,$(getcfg,BLOCKLEVELOFDETAIL),1)</Command>
               <HelpString>Toggles Block Level of Detail high/low. </HelpString>
               <Image ID="bimblocklevelofdetail"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bimsetlevelofdetail">
            <Macro>
               <Name>Composition Level of Detail</Name>
               <Command>'LEVELOFDETAIL;$M=$(if,$(&gt;,1,$(getcfg,LEVELOFDETAIL)),2,0)</Command>
               <HelpString>Toggles Composition Level of Detail high/low.</HelpString>
               <Image ID="bimsetlevelofdetail"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bimrendercompositionmaterial">
            <Macro>
               <Name>Render Composition Material</Name>
               <Command>'RENDERCOMPOSITIONMATERIAL;$M=$(xor,$(getcfg,RENDERCOMPOSITIONMATERIAL),1)</Command>
               <HelpString>Toggles the render of material compositions on/off.</HelpString>
               <Image ID="bimrendercompositionmaterial"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bimgraphicoverride">
            <Macro>
               <Name>Graphic Override</Name>
               <Command>^c^c_GRAPHICOVERRIDE</Command>
               <HelpString>Temporarily modifies the color, transparency and visibility of entities, based on BIM properties. (GRAPHICOVERRIDE)</HelpString>
               <Image ID="bimgraphicoverride"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bimpython">
            <Macro>
               <Name>Python...</Name>
               <Command>^c^c_BIMPYTHON</Command>
               <HelpString>Opens the Select Python Script dialog and runs the chosen script. (BIMPYTHON)</HelpString>
               <Image ID="bim_python"/>
            </Macro>
         </MenuMacro>
      </MacroGroup>
      <MacroGroup Name="Bricsys">
         <MenuMacro UID="url_homepage">
            <Macro>
               <Name>Bricsys Website...</Name>
               <Command>$M=^c^c_url;https://www.bricsys.com/?utm_source=bricscad&amp;utm_medium=helpmenu&amp;utm_campaign=help_about </Command>
               <HelpString>Opens the Bricsys website.</HelpString>
               <Image ID="bricsys"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="url_releasenotes">
            <Macro>
               <Name>Release Notes...</Name>
               <Command>^c^c^P(command "_url" (findfile "ReleaseNotes.htm"))(princ)^P</Command>
