      <MacroGroup Name="Point Clouds">
         <MenuMacro UID="pc_attach">
            <Macro>
               <Name>Attach</Name>
               <Command>^c^c_pointcloudattach</Command>
               <HelpString>Attaches a point cloud to the current drawing. (POINTCLOUDATTACH)</HelpString>
               <Image ID="pc_attach"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pc_ptsize_increase">
            <Macro>
               <Name>Increase point size</Name>
               <Command>^c^c_pointcloudpointsize_plus</Command>
               <HelpString>Makes point cloud points x2 as large.</HelpString>
               <Image ID="pc_ptsize_increase"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pc_ptsize_decrease">
            <Macro>
               <Name>Decrease point size</Name>
               <Command>^c^c_pointcloudpointsize_minus</Command>
               <HelpString>Makes point cloud points x0.5 the size.</HelpString>
               <Image ID="pc_ptsize_decrease"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pc_eye_dome_lighting">
            <Macro>
               <Name>Eye Dome Lighting</Name>
               <Command>^c^c_pointcloudeyedomelighting</Command>
               <HelpString>Eye dome lighting strength.</HelpString>
               <Image ID="pc_eye_dome_lighting"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pc_rendersettings">
            <Macro>
               <Name>Render Settings</Name>
               <Command>^c^c_pointcloudrendersettingsopen</Command>
               <HelpString>Point Cloud Render Settings.</HelpString>
               <Image ID="pc_rendersettings"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pc_gap_filling">
            <Macro>
               <Name>Gap filling</Name>
               <Command>^c^c_pointcloudgapfilling</Command>
               <HelpString>Gap between points to fill in pixels.</HelpString>
               <Image ID="pc_gap_filling"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pc_colormap">
            <Macro>
               <Name>Colormap</Name>
               <Command>^c^c_pointcloudcolormap</Command>
               <HelpString>Assigns color to a point cloud based on a range of variables. (POINTCLOUDCOLORMAP)</HelpString>
               <Image ID="pc_colormap"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pc_crop_generic">
            <Macro>
               <Name>Crop</Name>
               <Command>^c^c_pointcloudcrop;</Command>
               <HelpString>Crops a point cloud to limit the displayed points to a specific area. (POINTCLOUDCROP)</HelpString>
               <Image ID="pc_crop_rectangular"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pc_crop_rectangular">
            <Macro>
               <Name>Crop Rectangular</Name>
               <Command>^c^c_pointcloudcrop;_r</Command>
               <HelpString>Crops the point cloud with a cuboid shape.</HelpString>
               <Image ID="pc_crop_rectangular"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pc_crop_circular">
            <Macro>
               <Name>Crop Circular</Name>
               <Command>^c^c_pointcloudcrop;_c</Command>
               <HelpString>Crops the point cloud with a cylinder shape.</HelpString>
               <Image ID="pc_crop_circular"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pc_crop_polygonal">
            <Macro>
               <Name>Crop Polygonal</Name>
               <Command>^c^c_pointcloudcrop;_p</Command>
               <HelpString>Crops the point cloud with a polygon, prism shape.</HelpString>
               <Image ID="pc_crop_polygonal"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pc_crop_invert">
            <Macro>
               <Name>Crop Invert</Name>
               <Command>^c^c_pointcloudcrop;_i</Command>
               <HelpString>Toggles the point cloud crop inside/outside.</HelpString>
               <Image ID="pc_crop_invert"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pc_crop_enable">
            <Macro>
               <Name>Crop Toggle</Name>
               <Command>^c^c_pointcloudcrop;_t</Command>
               <HelpString>Toggle point cloud crop display on/off.</HelpString>
               <Image ID="pc_crop_enable"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pc_crop_remove">
            <Macro>
               <Name>Crop Remove</Name>
               <Command>^c^c_pointcloudcrop;_a</Command>
               <HelpString>Delete a point cloud crop.</HelpString>
               <Image ID="pc_crop_remove"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pc_reference">
            <Macro>
               <Name>Reference</Name>
               <Command>^c^c_pointcloudreference</Command>
               <HelpString>Opens the Point Cloud Reference Manager dialog, use to manage and insert point cloud files stored in the cache. (POINTCLOUDREFERENCE)</HelpString>
               <Image ID="pc_reference"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pc_delete_item">
            <Macro>
               <Name>Delete Item</Name>
               <Command>^c^c_pointclouddeleteitem</Command>
               <HelpString>Opens the Point Cloud Reference Manager dialog, use to delete selected point cloud files from the cache. (POINTCLOUDDELETEITEM)</HelpString>
               <Image ID="pc_delete_item"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pc_align">
            <Macro>
               <Name>Align</Name>
               <Command>^c^c_pointcloudalign</Command>
               <HelpString>Rotates the point cloud to optimally align it with the X and Y axes in the world coordinate system. (POINTCLOUDALIGN)</HelpString>
               <Image ID="pc_align"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pc_export">
            <Macro>
               <Name>Export</Name>
               <Command>^c^c_pointcloudexport</Command>
               <HelpString>Exports a point cloud crop selection to a .pts, .Hspc or .laz file. (POINTCLOUDEXPORT)</HelpString>
               <Image ID="pc_export"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pc_detect_floors">
            <Macro>
               <Name>Detect Floors</Name>
               <Command>^c^c_pointclouddetectfloors</Command>
               <HelpString>Automatically generates volume sections for each floor found in a point cloud, works with buildings only. (POINTCLOUDDETECTFLOORS)</HelpString>
               <Image ID="pc_detect_floors"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pc_detect_rooms">
            <Macro>
               <Name>Detect Rooms</Name>
               <Command>^c^c_pointclouddetectrooms</Command>
               <HelpString>Automatically segments a point cloud of a building into separate rooms. (POINTCLOUDDETECTROOMS)</HelpString>
               <Image ID="pc_detect_rooms"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pc_fit_rooms">
            <Macro>
               <Name>Fit Rooms</Name>
               <Command>^c^c_pointcloudfitrooms</Command>
               <HelpString>Automatically detects room shapes in a point cloud and creates solid geometry to fit. (POINTCLOUDFITROOMS) [Beta]</HelpString>
               <Image ID="pc_fit_rooms"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pc_fit_planar">
            <Macro>
               <Name>Fit Planar</Name>
               <Command>^c^c_pointcloudfitplanar</Command>
               <HelpString>Searches a point cloud for a dense set of planar points around a point(s) and creates a planar surface, or a solid if applicable. (POINTCLOUDFITPLANAR)</HelpString>
               <Image ID="pc_fit_planar"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pc_project_section">
            <Macro>
               <Name>Project Section</Name>
               <Command>^c^c_pointcloudprojectsection</Command>
               <HelpString>Automatically generates a 2D raster image, with optional contour lines, from a section box. (POINTCLOUDPROJECTSECTION)</HelpString>
               <Image ID="pc_project_section"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pc_crop_solid">
            <Macro>
               <Name>Crop Solid</Name>
               <Command>^c^c_pointcloudcropsolid</Command>
               <HelpString>Converts a solid to a crop solid. (POINTCLOUDCROPSOLID)</HelpString>
               <Image ID="pc_crop_solid"/>
            </Macro>
         </MenuMacro>
         
         <MenuMacro UID="pc_fit_cylinder">
            <Macro>
               <Name>Fit Cylinder</Name>
               <Command>^c^c_pointcloudfitcylinder</Command>
               <HelpString>Searches a point cloud for a dense set of points and creates a cylinder. (POINTCLOUDFITCYLINDER)</HelpString>
               <Image ID="pc_fit_cylinder"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pc_deviation">
            <Macro>
               <Name>Deviation</Name>
               <Command>^c^c_pointclouddeviation</Command>
               <HelpString>Assigns colors to point cloud points, to visualize the deviation. (POINTCLOUDDEVIATION)</HelpString>
               <Image ID="pc_deviation"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pc_settings">
            <Macro>
               <Name>Settings</Name>
               <Command>^c^c_settingssearch;PointCloudB</Command>
               <HelpString>Opens the Settings dialog and displays the point cloud settings.</HelpString>
               <Image ID="settings"/>
            </Macro>
         </MenuMacro>
         
      </MacroGroup>
      <MacroGroup Name="Power Dimensions">
         <MenuMacro UID="ampowerdim">
            <Macro>
               <Name>Power Dimension</Name>
               <Command>^c^c_pdim</Command>
               <HelpString>Draws multiple dimension types in a single workflow, automatically detects the correct dimension type for each entity, with the ability to specify tolerances or automatically fit as appropriate. (PDIM)</HelpString>
               <Image ID="dimension"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="ampowerdim_ali">
            <Macro>
               <Name>Aligned</Name>
               <Command>^c^c_ampowerdim_ali</Command>
               <HelpString>Draws an aligned dimension - parallel to the start and end points. (AMPOWERDIM_ALI)</HelpString>
               <Image ID="dim_power_aligned"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="ampowerdim_hor">
            <Macro>
               <Name LocalizationId="ampowerdim_hor">Horizontal</Name>
               <Command>^c^c_ampowerdim_hor</Command>
               <HelpString>Draws a horizontal dimension. (AMPOWERDIM_HOR)</HelpString>
               <Image ID="dim_power_hor"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="ampowerdim_ver">
            <Macro>
               <Name LocalizationId="ampowerdim_ver">Vertical</Name>
               <Command>^c^c_ampowerdim_ver</Command>
               <HelpString>Draws a vertical dimension. (AMPOWERDIM_VER)</HelpString>
               <Image ID="dim_power_ver"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="ampowerdim_rot">
            <Macro>
               <Name>Rotated</Name>
               <Command>^c^c_ampowerdim_rot</Command>
               <HelpString>Draws a linear dimension, at an angle. (AMPOWERDIM_ROT)</HelpString>
               <Image ID="dim_pow_rotate"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="ampowerdim_ang">
            <Macro>
               <Name>Angular</Name>
               <Command>^c^c_ampowerdim_ang</Command>
               <HelpString>Draws an angle dimension. (AMPOWERDIM_ANG)</HelpString>
               <Image ID="dim_pow_ang"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="ampowerdim_rad">
            <Macro>
               <Name>Radius</Name>
               <Command>^c^c_ampowerdim_rad</Command>
               <HelpString>Draws a radius dimension on a circle or an arc. (AMPOWERDIM_RAD)</HelpString>
               <Image ID="dim_pow_rad"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="ampowerdim_dia">
            <Macro>
               <Name>Diameter</Name>
               <Command>^c^c_ampowerdim_dia</Command>
               <HelpString>Draws a diameter dimension on a circle or an arc. (AMPOWERDIM_DIA)</HelpString>
               <Image ID="dim_pow_dia"/>
            </Macro>
         </MenuMacro>
      </MacroGroup>
      <MacroGroup Name="Ref Edit">
         <MenuMacro UID="refedit">
            <Macro>
               <Name>Refedit</Name>
               <Command>^c^c_refedit</Command>
               <HelpString>Edits block references and externally referenced drawings. (REFEDIT)</HelpString>
               <Image ID="refedit"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="refclose_save">
            <Macro>
               <Name>Refclose and Save</Name>
               <Command>^c^c_refclose;$M=$(if,$(eq,$(getvar,refeditname),""),,_save)</Command>
               <HelpString>Ends Refedit and saves changes.</HelpString>
               <Image ID="refclose_save"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="refclose_discard">
            <Macro>
               <Name>Refclose and Discard</Name>
               <Command>^c^c_refclose;$M=$(if,$(eq,$(getvar,refeditname),""),,_discard)</Command>
               <HelpString>Ends Refedit and discards changes.</HelpString>
               <Image ID="refclose_discard"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="refset_add">
            <Macro>
               <Name>Add to Refedit</Name>
               <Command>^c^c_refset;$M=$(if,$(eq,$(getvar,refeditname),""),,_add)</Command>
               <HelpString>Adds entities to the Refedit selection.</HelpString>
               <Image ID="refset_add"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="refset_remove">
            <Macro>
               <Name>Remove from Refedit</Name>
               <Command>^c^c_refset;$M=$(if,$(eq,$(getvar,refeditname),""),,_remove)</Command>
               <HelpString>Removes entities from the Refedit selection.</HelpString>
               <Image ID="refset_remove"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bedit">
            <Macro>
               <Name>Edit Block</Name>
               <Command>^c^c_bedit</Command>
               <HelpString>Edits a block. (BEDIT)</HelpString>
               <Image ID="bedit"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bedit_save">
            <Macro>
               <Name>Bclose and Save</Name>
               <Command>^c^c_bclose;$M=$(if,$(eq,$(getvar,blockeditor),0),,_save)</Command>
               <HelpString>Ends block edit (BEdit) mode and saves changes.</HelpString>
               <Image ID="bedit_save"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bedit_saveas">
            <Macro>
               <Name>Save As Block</Name>
               <Command>^c^c_bsaveas</Command>
               <HelpString>Saves the currently open block to the current drawing, as a new block, with a new name. (BSAVEAS)</HelpString>
               <Image ID="bsaveas"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bedit_discard">
            <Macro>
               <Name>Bclose and Discard</Name>
               <Command>^c^c_bclose;$M=$(if,$(eq,$(getvar,blockeditor),0),,_discard)</Command>
               <HelpString>Ends block edit (BEdit) mode and discards changes.</HelpString>
               <Image ID="bedit_discard"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="resetblock">
            <Macro>
               <Name>Reset Block</Name>
               <Command>^c^c_resetblock</Command>
               <HelpString>Resets parametric blocks to default values. (RESETBLOCK)</HelpString>
               <Image ID="resetblock"/>
            </Macro>
