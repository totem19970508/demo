               <Image ID="pasteclip"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pasteblock">
            <Macro>
               <Name>Paste as Block</Name>
               <Command>^c^c_pasteblock</Command>
               <HelpString>Pastes a copied block. (PASTEBLOCK)</HelpString>
               <Image ID="pasteblock"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="pasteorig">
            <Macro>
               <Name>Paste to Original Coordinates</Name>
               <Command>^c^c_pasteorig</Command>
               <HelpString>Pastes entities from the Clipboard into a different drawing, with the same coordinates. (PASTEORIG)</HelpString>
               <Image ID="pasteorig"/>
            </Macro>
         </MenuMacro>
         
         <MenuMacro UID="addselected">
            <Macro>
               <Name>Add selected</Name>
               <Command>^c^c_addselected</Command>
               <HelpString>Creates a new entity of the same type and with the same properties as another entity. (ADDSELECTED)</HelpString>
               <Image ID="addselected"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="selectsimilar">
            <Macro>
               <Name>Select Similar</Name>
               <Command>^c^c_selectsimilar</Command>
               <HelpString>Selects all entities in the current drawing that match the properties of an entity. (SELECTSIMILAR)</HelpString>
               <Image ID="selectsimilar"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="select">
            <Macro>
               <Name>Quick Select</Name>
               <Command>^c^c_qselect</Command>
               <HelpString>Opens the Properties panel in Quick Select mode to display it in the current workspace. (QSELECT)</HelpString>
               <Image ID="quick_select"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="matchprop">
            <Macro>
               <Name>Match</Name>
               <Command>^c^c_matchprop</Command>
               <HelpString>Copies selected properties and styles from one entity and applies it to another. (MATCHPROP)</HelpString>
               <Image ID="matchprop"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="erase">
            <Macro>
               <Name>Erase</Name>
               <Command>^c^c_erase</Command>
               <HelpString>Deletes entities. (ERASE)</HelpString>
               <Image ID="erase"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="erase3d">
            <Macro>
               <Name>Erase</Name>
               <Command>^c^c_erase</Command>
               <HelpString>Deletes entities. (ERASE)</HelpString>
               <Image ID="erase"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="overkill">
            <Macro>
               <Name>Overkill</Name>
               <Command>^c^c_overkill</Command>
               <HelpString>Deletes duplicate entities, overlapping lines, arcs, and polylines, and unifies partly overlapping or contiguous lines. (OVERKILL)</HelpString>
               <Image ID="overkill"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="oops">
            <Macro>
               <Name>Oops</Name>
               <Command>^c^c_oops</Command>
               <HelpString>Restores the last erased entity. (OOPS)</HelpString>
               <Image ID="oops"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="delete_all">
            <Macro>
               <Name>Clear Drawing</Name>
