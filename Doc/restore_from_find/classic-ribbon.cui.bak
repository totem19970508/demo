         <MenuMacro UID="dmaudit">
            <Macro>
               <Name>Audit 3D</Name>
               <Command>^c^c_dmAudit</Command>
               <HelpString>Checks and automatically fixes problems found in 3D geometry: 3D solids and surfaces. (DMAUDIT)</HelpString>
               <Image ID="dm_repair"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dmupdate">
            <Macro>
               <Name>Update</Name>
               <Command>^c^c_dmUpdate</Command>
               <HelpString>Updates all 3D constraints. (DMUPDATE)</HelpString>
               <Image ID="updatefield"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dmoptions">
            <Macro>
               <Name>Options</Name>
               <Command>^c^c_settingssearch;DMRECOGNIZE</Command>
               <HelpString>Opens the Settings dialog at Direct Modeling section.</HelpString>
               <Image ID="options"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dmradius">
            <Macro>
               <Name>Radius</Name>
               <Command>^c^c_dmRadius3d</Command>
               <HelpString>Applies a radius constraint to cylindrical surfaces or circular edges. (DMRADIUS3D)</HelpString>
               <Image ID="dc3d_radius"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dmdistance">
            <Macro>
               <Name>Distance</Name>
               <Command>^c^c_dmDistance3d</Command>
               <HelpString>Applies a distance constraint between two subentities of a solid, or two different solids. (DMDISTANCE3D)</HelpString>
               <Image ID="dc3d_distance"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dmangle">
            <Macro>
               <Name>Angle</Name>
               <Command>^c^c_dmAngle3d</Command>
               <HelpString>Applies an angle constraint between two faces of a solid, or two different solids. (DMANGLE3D)</HelpString>
               <Image ID="dc3d_angle"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dmconeangle">
            <Macro>
               <Name>Cone Angle</Name>
               <Command>^c^c_dmAngle3d;_A</Command>
               <HelpString>Applies a cone angle constraint.</HelpString>
               <Image ID="dc3d_angle_object"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dmfix">
            <Macro>
               <Name>Fix</Name>
               <Command>^c^c_dmFix3d;_M</Command>
               <HelpString>Applies a fix constraint to a solid, an edge, or the face of a solid. (DMFIX3D)</HelpString>
               <Image ID="gc_fix"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dmcoincident">
            <Macro>
               <Name>Coincident</Name>
               <Command>^c^c_dmCoincident3d</Command>
               <HelpString>Applies a coincidence constraint between two edges, two faces, or the edge or face of two different solids. (DMCOINCIDENT3D)</HelpString>
               <Image ID="gc3d_coincident"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dmconcentric">
            <Macro>
               <Name>Concentric</Name>
               <Command>^c^c_dmConcentric3d</Command>
               <HelpString>Applies a concentric constraint between two cylindrical, spherical or conical surfaces. (DMCONCENTRIC3D)</HelpString>
               <Image ID="gc3d_concentric"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dmparallel">
            <Macro>
               <Name>Parallel</Name>
               <Command>^c^c_dmParallel3d</Command>
               <HelpString>Applies a parallel constraint between two faces of a solid, or different solids. (DMPARALLEL3D)</HelpString>
               <Image ID="gc3d_parallel"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dmperpendicular">
            <Macro>
               <Name>Perpendicular</Name>
               <Command>^c^c_dmPerpendicular3d</Command>
               <HelpString>Applies a perpendicular constraint between two faces of a solid, or different solids. (DMPERPENDICULAR3D)</HelpString>
               <Image ID="gc3d_perpendicular"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dmtangent">
            <Macro>
               <Name>Tangent</Name>
               <Command>^c^c_dmTangent3d</Command>
               <HelpString>Applies a tangent constraint between a face and a curved surface of different solids. (DMTANGENT3D)</HelpString>
               <Image ID="gc3d_tangent"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dmrigidset">
            <Macro>
               <Name>Rigid Set</Name>
               <Command>^c^c_dmRigidSet3d</Command>
               <HelpString>Defines a set of entities or subentities as a rigid body. (DMRIGIDSET3D)</HelpString>
               <Image ID="gc3d_rigidset"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="dmpath">
            <Macro>
               <Name>Path Constraint</Name>
               <Command>^c^c_dmPath3d</Command>
               <HelpString>Applies a path constraint between a point and a curve; allows a point to move along a curve. (DMPATH3D)</HelpString>
               <Image ID="dc3d_path"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="workplaneactivate">
            <Macro>
               <Name>Start sketching</Name>
               <Command>^c^c_workPlaneActivate</Command>
               <HelpString>Activates a work plane to enable sketching. (WORKPLANEACTIVATE)</HelpString>
               <Image ID="workplane_activate"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="workplanecreate_face">
            <Macro>
               <Name>Create face work plane</Name>
               <Command>^c^c_workPlaneCreate;_Face</Command>
               <HelpString>Creates a work plane that is attached to a face (WORKPLANECREATE)</HelpString>
               <Image ID="workplane_create"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="workplanecreate_offset">
            <Macro>
               <Name>Create offset work plane</Name>
               <Command>^c^c_workPlaneCreate;_Offset</Command>
               <HelpString>Creates a work plane that is offset from another work plane or a face (WORKPLANECREATE)</HelpString>
               <Image ID="workplane_create"/>
            </Macro>
         </MenuMacro>
      </MacroGroup>
