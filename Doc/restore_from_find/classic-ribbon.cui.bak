      <MacroGroup Name="Select">
         <MenuMacro UID="select">
            <Macro>
               <Name>Select</Name>
               <Command>'_select</Command>
               <HelpString>Selects one or more entities through a variety of selection methods. (SELECT)</HelpString>
               <Image ID="select"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="select_all">
            <Macro>
               <Name>Select All</Name>
               <Command>^c^c_selgrips;_all;;</Command>
               <HelpString>Adds entities to the current selection.</HelpString>
               <Image ID="select_all"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="select_none">
            <Macro>
               <Name>Deselect</Name>
               <Command>^c^c_selgrips;;</Command>
               <HelpString>Deselects all entities.</HelpString>
               <Image ID="deselect"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="select_add">
            <Macro>
               <Name>Select Add</Name>
               <Command>$M=$(if,$(getvar,cmdactive),$(if,$(eq,$(getvar,cmdnames),SELECT),_+;,),_select;_+)</Command>
               <HelpString>Adds entities to the current selection.</HelpString>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="select_remove">
            <Macro>
               <Name>Select Remove</Name>
               <Command>$M=$(if,$(getvar,cmdactive),$(if,$(eq,$(getvar,cmdnames),SELECT),_-;,),_select;_-)</Command>
               <HelpString>Removes entities from the current selection.</HelpString>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="select_crossing">
            <Macro>
               <Name>Select Crossing</Name>
               <Command>$M=$(if,$(getvar,cmdactive),$(if,$(eq,$(getvar,cmdnames),SELECT),_c;,),_select;_c)</Command>
               <HelpString>Selects all entities, partly or completely inside, a rectangular selection window.</HelpString>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="select_window">
            <Macro>
               <Name>Select Window</Name>
               <Command>$M=$(if,$(getvar,cmdactive),$(if,$(eq,$(getvar,cmdnames),SELECT),_w;,),_select;_w)</Command>
               <HelpString>Selects all entities completely inside a rectangular selection window.</HelpString>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="select_cpolygon">
            <Macro>
               <Name>Select Crossing Polygon</Name>
               <Command>$M=$(if,$(getvar,cmdactive),$(if,$(eq,$(getvar,cmdnames),SELECT),_cp;,),_select;_cp)</Command>
               <HelpString>Selects entities that cross a polygon selection window.</HelpString>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="select_wpolygon">
            <Macro>
               <Name>Select Window Polygon</Name>
               <Command>$M=$(if,$(getvar,cmdactive),$(if,$(eq,$(getvar,cmdnames),SELECT),_wp;,),_select;_wp)</Command>
               <HelpString>Selects entities inside a polygon selection window.</HelpString>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="select_fence">
            <Macro>
               <Name>Select Fence</Name>
               <Command>$M=$(if,$(getvar,cmdactive),$(if,$(eq,$(getvar,cmdnames),SELECT),_f;,),_select;_f)</Command>
               <HelpString>Selects all entities that cross a selection fence.</HelpString>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="select_group">
            <Macro>
               <Name>Select Group</Name>
               <Command>$M=$(if,$(getvar,cmdactive),$(if,$(eq,$(getvar,cmdnames),SELECT),_g;,),_select;_g)</Command>
               <HelpString>Selects all entities within a group.</HelpString>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="select_last">
            <Macro>
               <Name>Select Last</Name>
               <Command>$M=$(if,$(getvar,cmdactive),$(if,$(eq,$(getvar,cmdnames),SELECT),_l;,),_select;_l)</Command>
               <HelpString>Selects the most recently created, visible entity.</HelpString>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="select_previous">
            <Macro>
               <Name>Select Previous</Name>
               <Command>$M=$(if,$(getvar,cmdactive),$(if,$(eq,$(getvar,cmdnames),SELECT),_p;,),_select;_p)</Command>
               <HelpString>Reselects the last selected entity/entities.</HelpString>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="selectalignedfaces">
            <Macro>
               <Name>Select Aligned Faces</Name>
               <Command>^c^c_selectalignedfaces</Command>
               <HelpString>Selects all faces in a model that are coplanar (inline) with a given face. (SELECTALIGNEDFACES)</HelpString>
               <Image ID="sel_aligned_faces"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="selectalignedsolids">
            <Macro>
               <Name>Select Aligned Solids</Name>
               <Command>^c^c_selectalignedsolids</Command>
               <HelpString>Selects all solids that have a face coplanar (inline) with a given face. (SELECTALIGNEDSOLIDS)</HelpString>
               <Image ID="sel_aligned_solids"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="selectconnectedfaces">
            <Macro>
               <Name>Select Connected Faces</Name>
               <Command>^c^c_selectconnectedfaces</Command>
               <HelpString>Selects all faces connected to a given face. (SELECTCONNECTEDFACES)</HelpString>
               <Image ID="sel_connected_faces"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="selectconnectedsolids">
            <Macro>
               <Name>Select Connected Solids</Name>
               <Command>^c^c_selectconnectedsolids</Command>
               <HelpString>Selects all solids in a model that are connected to a given face. (SELECTCONNECTEDSOLIDS)</HelpString>
               <Image ID="sel_connected_solids"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="selectionmodes_faces">
            <Macro>
               <Name>Prioritize Selection of Faces</Name>
               <Command>'SELECTIONMODES;$M=$(if,$(&gt;,0,$(getvar,SELECTIONMODES)),2,$(xor,$(getvar,SELECTIONMODES),2))</Command>
               <HelpString>Controls if 3D solid faces are selectable and if they are highlighted in selection preview.</HelpString>
               <Image ID="selectionmodes_faces"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="selectionmodes_edges">
            <Macro>
               <Name>Prioritize Selection of Edges</Name>
               <Command>'SELECTIONMODES;$M=$(if,$(&gt;,0,$(getvar,SELECTIONMODES)),1,$(xor,$(getvar,SELECTIONMODES),1))</Command>
               <HelpString>Controls if 3D solid edges are selectable and if they are highlighted in selection preview.</HelpString>
               <Image ID="selectionmodes_edges"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="selectionmodes_vertices">
            <Macro>
               <Name>Prioritize Selection of Vertices</Name>
               <Command>'SELECTIONMODES;$M=$(if,$(&gt;,0,$(getvar,SELECTIONMODES)),8,$(xor,$(getvar,SELECTIONMODES),8))</Command>
               <HelpString>Controls if 3D solid vertices are selectable and if they are highlighted in selection preview.</HelpString>
               <Image ID="selectionmodes_vertices"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="selectionmodes_boundary">
            <Macro>
               <Name>Enable Boundary Detection</Name>
               <Command>'SELECTIONMODES;$M=$(if,$(&gt;,0,$(getvar,SELECTIONMODES)),4,$(xor,$(getvar,SELECTIONMODES),4))</Command>
               <HelpString>Controls if boundaries are detected, when no command is active.</HelpString>
               <Image ID="selectionmodes_boundary"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="displaysidesandends">
            <Macro>
               <Name>Display Sides and Ends</Name>
               <Command>'DISPLAYSIDESANDENDS;$M=$(if,$(&gt;,0,$(getcfg,DISPLAYSIDESANDENDS)),1,$(xor,$(getcfg,DISPLAYSIDESANDENDS),1))</Command>
               <HelpString>Controls if sides and ends are selectable and if they are highlighted in selection preview.</HelpString>
               <Image ID="displaysidesandends"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="displayaxes">
            <Macro>
               <Name>Display Axes</Name>
               <Command>'DISPLAYAXES;$M=$(if,$(and,$(getcfg,DISPLAYAXES),$(getcfg,DISPLAYAXESFORMEP)),0,1);'DISPLAYAXESFORMEP;$M=$(if,$(and,$(if,$(getcfg,DISPLAYAXES),1,0),$(getcfg,DISPLAYAXESFORMEP)),0,1)</Command>
               <HelpString>Controls the display of structural/MEP elements' axes.</HelpString>
               <Image ID="displayaxes"/>
            </Macro>
         </MenuMacro>
      </MacroGroup>
