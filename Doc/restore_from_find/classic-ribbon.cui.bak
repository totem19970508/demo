               <Name>Hide all unused parts</Name>
               <Image ID="mcad_eye_crossed"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="mcad_hashtag">
            <Macro>
               <Name>Renumerate all steps</Name>
               <Image ID="mcad_hashtag"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="mcad_play_arrow">
            <Macro>
               <Name>Animate exploded view</Name>
               <Image ID="mcad_play_arrow"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="mcad_refresh">
            <Macro>
               <Name>Update view from current</Name>
               <Image ID="mcad_refresh"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="mcad_remove">
            <Macro>
               <Name>Delete view or step</Name>
               <Image ID="mcad_remove"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="mcad_save_step">
            <Macro>
               <Name>Save an exploded view step</Name>
               <Image ID="mcad_save_step"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="mcad_split_exploded_view_steps">
            <Macro>
               <Name>Split exploded view steps</Name>
               <Image ID="mcad_split_exploded_view_steps"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="mcad_update_camera_view">
            <Macro>
               <Name>Update the camera view of an exploded view step</Name>
               <Image ID="mcad_update_camera_view"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="mcad_comp_new">
            <Macro>
               <Name>New Component</Name>
               <Command>^c^c_bmNew;;</Command>
               <HelpString>Creates a new component. (BMNEW)</HelpString>
               <Image ID="mcad_comp_new"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bminsert">
            <Macro>
               <Name>Insert Component</Name>
               <Command>^c^c_bmInsert</Command>
               <HelpString>Inserts a component. (BMINSERT)</HelpString>
               <Image ID="insert"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bminsert_smart">
            <Macro>
               <Name>Smart Insert Component</Name>
               <Command>^c^c_bmInsert;_T;_Local;_SMART</Command>
               <HelpString>Inserts and connects a new piping standard part to a piping standard part already in the drawing, automatically creates 3D constraints between the two parts, and copies expressions for the parameters of the existing part to the new part.</HelpString>
               <Image ID="bminsert_smart"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="mcad_connect">
            <Macro>
               <Name>Connect Components</Name>
               <Command>^c^c_bmConnect</Command>
               <HelpString>Connects two components to each other. (BMCONNECT)</HelpString>
               <Image ID="mcad_connect"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bmassemblyinspect">
            <Macro>
               <Name>Assembly Inspect</Name>
               <Command>^c^c_bmassemblyinspect</Command>
               <HelpString>Evaluates an assembly sequence against a specified criteria, such as clearance and visibility. (BMASSEMBLYINSPECT)</HelpString>
               <Image ID="bmassemblyinspect"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="mcad_partref">
            <Macro>
               <Name>Part Reference</Name>
               <Command>^c^c_ampartref</Command>
               <HelpString>Creates a part reference symbol to visually mark 2D geometry as a part, with metadata. Part references are associative with part lists created with the AMPARTLIST commands and balloons created with AMBALLOON command. (AMPARTREF)</HelpString>
               <Image ID="ampartref"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="mcad_insert_standard_part">
            <Macro>
               <Name>Standard Part</Name>
               <Command>^c^c_bmHardware</Command>
               <HelpString>Inserts a standard part. (BMHARDWARE)</HelpString>
               <Image ID="mcad_insert_standard_part"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bim_convert_standard_part">
            <Macro>
               <Name>Convert</Name>
               <Command>^c^c_bmConvert</Command>
               <HelpString>Converts BIM linear solids, with circular profiles, into Mechanical assemblies. (BMCONVERT)</HelpString>
               <Image ID="bimconvertstandardpart"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="mcad_comp_make">
            <Macro>
               <Name>Form Component</Name>
               <Command>^c^c_bmForm</Command>
               <HelpString>Creates a new mechanical component and inserts it into the current drawing. (BMFORM)</HelpString>
               <Image ID="mcad_comp_make"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="mcad_create_comp">
            <Macro>
               <Name>Create Component</Name>
               <Command>^c^c_bmCreateComponent</Command>
               <HelpString>Creates a component and adds it to the Components panel. (BMCREATECOMPONENT)</HelpString>
               <Image ID="mcad_create_comp"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="mcad_dissolve">
            <Macro>
               <Name>Dissolve Component</Name>
               <Command>^c^c_bmDissolve</Command>
               <HelpString>Dissolves a mechanical component, all the subcomponents of a dissolved component are moved up one level in the mechanical hierarchy. (BMDISSOLVE)</HelpString>
               <Image ID="mcad_dissolve"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bmlink">
            <Macro>
               <Name>Link Component</Name>
               <Command>^c^c_bmLink</Command>
               <HelpString>Links a solid to a component, to subtract from/unite with. (BMLINK)</HelpString>
               <Image ID="bmlink"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bmunlink">
            <Macro>
               <Name>Unlink Component</Name>
               <Command>^c^c_bmUnlink</Command>
               <HelpString>Unlinks a solid from a component, so it does not subtract or unite. (BMUNLINK)</HelpString>
               <Image ID="bmunlink"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="mcad_mechit">
            <Macro>
               <Name>Initialize Mechanical Structure</Name>
               <Command>^c^c_bmMech;;</Command>
               <HelpString>Converts the current drawing into a mechanical component. (BMMECH)</HelpString>
               <Image ID="mcad_mechit"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="mcad_mechit_cmp">
            <Macro>
               <Name>Initialize Components Structure</Name>
               <Command>^c^c_bmMech;;</Command>
               <HelpString>Converts the current drawing into a mechanical component. (BMMECH)</HelpString>
               <Image ID="mcad_mechit"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="mcad_hide">
            <Macro>
               <Name>Hide</Name>
               <Command>^c^c_bmHide</Command>
               <HelpString>Hides a component. (BMHIDE)</HelpString>
               <Image ID="mcad_hide"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="mcad_show">
            <Macro>
               <Name>Show</Name>
               <Command>^c^c_bmShow</Command>
               <HelpString>Shows hidden components. (BMSHOW)</HelpString>
               <Image ID="mcad_show"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="mcad_part_wire">
            <Macro>
               <Name>Visual Style</Name>
               <Command>^c^c_bmVStyle</Command>
               <HelpString>Changes the visual style of a component. (BMVSTYLE)</HelpString>
               <Image ID="mcad_part_wire"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="balloon">
            <Macro>
               <Name>Balloon</Name>
               <Command>^c^c_bmBALLOON</Command>
               <HelpString>Draws associative balloon entities for assembly components. Works in conjunction with the BMBOM command. (BMBALLOON)</HelpString>
               <Image ID="balloon"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="balloonauto">
            <Macro>
               <Name>Balloon Auto</Name>
               <Command>^c^c_bmBALLOON;_AUTO</Command>
               <HelpString>Automatically draws and places associative balloon entities, for multiple assembly components at the same time. Works in conjunction with the BMBOM command.</HelpString>
               <Image ID="balloonauto"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="mcad_partlist">
            <Macro>
               <Name>Part List</Name>
               <Command>^c^c_ampartlist</Command>
               <HelpString>Creates a parts list. Works in conjunction with the AMPARTREF and AMBALLOON commands. (AMPARTLIST)</HelpString>
               <Image ID="ampartlist"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="mcad_bom">
            <Macro>
               <Name>Bill of Materials</Name>
               <Command>^c^c_bmBOM</Command>
               <HelpString>Generates a bill of materials. Works in conjunction with the BMBOM and BMBALLOON commands. (BMBOM)</HelpString>
               <Image ID="mcad_bom"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="ambomsettings">
            <Macro>
               <Name>BOM Settings</Name>
               <Command>^c^c_ambomsettings</Command>
               <HelpString>Launches the BOM Settings dialog. Use to configure part references properties, set up parts lists, and for data capture. Works in conjunction with the AMPARTREF and AMPARTLIST commands. (AMBOMSETTINGS)</HelpString>
               <Image ID="ambomsettings"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="mcad_mass_properties">
            <Macro>
               <Name>Mass Properties</Name>
               <Command>^c^c_bmMassprop</Command>
               <HelpString>Computes the mass properties of the current model from the assigned material densities. (BMMASSPROP)</HelpString>
               <Image ID="mcad_mass_properties"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="mcad_dependencies">
            <Macro>
               <Name>Dependencies</Name>
               <Command>^c^c_bmDependencies</Command>
               <HelpString>Lists all files, that contain component definitions for the current assembly, in the Command line. (BMDEPENDENCIES)</HelpString>
               <Image ID="mcad_dependencies"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="mcad_recover">
            <Macro>
               <Name>Recover</Name>
               <Command>^c^c_bmRecover</Command>
               <HelpString>Recovers a broken mechanical structure. (BMRECOVER)</HelpString>
               <Image ID="mcad_recover"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bmopen">
            <Macro>
               <Name>Open Component File</Name>
               <Command>^c^c_bmOpen</Command>
               <HelpString>Opens the source drawing of an external, mechanical component. (BMOPEN)</HelpString>
               <Image ID="open"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bmopencopy">
            <Macro>
               <Name>Open Component Copy</Name>
               <Command>^c^c_bmOpenCopy</Command>
               <HelpString>Opens a copy of a component, as a new file. (BMOPENCOPY)</HelpString>
               <Image ID="mcad_open_copy"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bmreplace">
            <Macro>
               <Name>Replace Component</Name>
               <Command>^c^c_bmReplace</Command>
               <HelpString>Replaces a mechanical component with another. (BMREPLACE)</HelpString>
               <Image ID="mcad_replace"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bmlocalize">
            <Macro>
               <Name>Switch Component to Local</Name>
               <Command>^c^c_bmlocalize</Command>
               <HelpString>Switches a component to a local component. (BMLOCALIZE)</HelpString>
               <Image ID="mcad_switch"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bmexternalize">
            <Macro>
               <Name>Switch Component to External</Name>
               <Command>^c^c_bmexternalize</Command>
               <HelpString>Switches a component to an external component. (BMEXTERNALIZE)</HelpString>
               <Image ID="mcad_externalize"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bmunmech">
            <Macro>
               <Name>Remove Structure</Name>
               <Command>^c^c_bmUnmech</Command>
               <HelpString>Removes the mechanical structure from the drawing. (BMUNMECH)</HelpString>
               <Image ID="acis_body_clean"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bmproperties">
            <Macro>
               <Name>Properties</Name>
               <Command>^c^c_bmproperties</Command>
               <HelpString>Opens the Mechanical Properties dialog, to create and manage properties. (BMPROPERTIES)</HelpString>
               <Image ID="bmproperties"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bmarrow_linear">
            <Macro>
               <Name>Linear Arrow Symbol</Name>
               <Command>^c^c_bmarrow</Command>
               <HelpString>Places arrow symbol to indicate movement of assembly parts. Either for assembly and disassembly or for functional assembly movements. (BMARROW)</HelpString>
               <Image ID="bmarrow_linear"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bmarrow_circular">
            <Macro>
               <Name>Circular Arrow Symbol</Name>
               <Command>^c^c_bmarrow;_c</Command>
               <HelpString>Places arrow symbol to indicate rotation of assembly parts. Either for assembly and disassembly or for functional assembly rotations. (BMARROW)</HelpString>
               <Image ID="bmarrow_circular"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="export_svg">
            <Macro>
               <Name>SVG Export</Name>
               <Command>^c^c_exportsvg</Command>
               <HelpString>Exports exploded views to SVG format. (EXPORTSVG)</HelpString>
               <Image ID="export_svg"/>
            </Macro>
         </MenuMacro>
      </MacroGroup>
      <MacroGroup Name="Attributes">
         <MenuMacro UID="attdef">
            <Macro>
               <Name>Define Attributes...</Name>
               <Command>^c^c_attdef</Command>
               <HelpString>Opens the Define Attribute dialog, to add an attribute to a block. (ATTDEF)</HelpString>
               <Image ID="attdef"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="eattedit">
            <Macro>
               <Name>Edit Block Attributes</Name>
               <Command>^c^c_eattedit</Command>
               <HelpString>Edits the values and most properties of all attributes contained in a single block, through the Attribute Editor dialog box. (EATTEDIT)</HelpString>
               <Image ID="eattedit"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="attedit">
            <Macro>
               <Name>Edit Attributes</Name>
               <Command>^c^c_attedit</Command>
               <HelpString>Edits the values and properties of attributes. (ATTEDIT)</HelpString>
               <Image ID="attedit"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="attredef">
            <Macro>
               <Name>Redefine Attribute Block</Name>
               <Command>^c^c_attredef</Command>
               <HelpString>Redefines a block and updates its attributes. (ATTREDEF)</HelpString>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="attsync">
            <Macro>
               <Name>Synchronize Attributes</Name>
               <Command>^c^c_attsync</Command>
               <HelpString>Updates a block with the attributes from another block. (ATTSYNC)</HelpString>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="attext">
            <Macro>
               <Name>Extract Attributes</Name>
               <Command>^c^c_attext</Command>
               <HelpString>Opens the Extract Attributes dialog, to export data from blocks to a text file. (ATTEXT)</HelpString>
               <Image ID="attext"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="attdisp">
            <Macro>
               <Name>Attribute Display</Name>
               <Command>^c^c_attdisp</Command>
               <HelpString>Sets the display mode of attribute text. (ATTDISP)</HelpString>
               <Image ID="attdisp"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="battman">
            <Macro>
               <Name>Block Attribute Manager...</Name>
               <Command>^c^c_battman</Command>
               <HelpString>Opens the Block Attribute Manager dialog, to view and modify block attribute definitions, properties and text. (BATTMAN)</HelpString>
               <Image ID="battman"/>
            </Macro>
         </MenuMacro>
      </MacroGroup>
      <MacroGroup Name="BIM">
         <MenuMacro UID="bimstructuralconnect">
            <Macro>
               <Name>Structural Connect</Name>
               <Command>^c^c_bimstructuralconnect</Command>
               <HelpString>Connects two structural solids. (BIMSTRUCTURALCONNECT)</HelpString>
               <Image ID="bimstructuralconnect"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bimflowconnect">
            <Macro>
               <Name>Flow Connect</Name>
               <Command>^c^c_bimflowconnect</Command>
               <HelpString>Creates a connection between flow segments, such as pipes or HVAC ducts. (BIMFLOWCONNECT)</HelpString>
               <Image ID="bimflowconnect"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="drag">
            <Macro>
               <Name>Drag</Name>
               <Command>^c^c_drag</Command>
               <HelpString>Moves 3D solids perpendicular to a select face. Optionally, preserves the connections to other solids. (DRAG)</HelpString>
               <Image ID="bimdrag"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bimcopy">
            <Macro>
               <Name>BIM Copy</Name>
               <Command>^c^c_bimcopy</Command>
               <HelpString>Creates copies from the planar faces of 3D solids, and the sides and ends of linear solids.</HelpString>
               <Image ID="bimcopy"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bimstretch">
            <Macro>
               <Name>Stretch</Name>
               <Command>^c^c_bimstretch</Command>
               <HelpString>Stretches the ends of linear solids and maintains connections between other linear solids. (BIMSTRETCH)</HelpString>
               <Image ID="gripstretch"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bimcurtainwall">
            <Macro>
               <Name>Curtain Wall</Name>
               <Command>^c^c_bimcurtainwall</Command>
               <HelpString>Creates a curtain wall, as a block, from the face of a solid. (BIMCURTAINWALL)</HelpString>
               <Image ID="bimcurtainwall"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bimpanelize">
            <Macro>
               <Name>Panelize</Name>
               <Command>^c^c_panelize</Command>
               <HelpString>Creates a grid on the face of a solid, as a block reference. (PANELIZE)</HelpString>
               <Image ID="bimpanelize"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bimgrid">
            <Macro>
               <Name>Rectangular Grid</Name>
               <Command>^c^c_bimgrid</Command>
               <HelpString>Creates a 2D, rectangular grid. (BIMGRID)</HelpString>
               <Image ID="bimgrid"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bimgridradial">
            <Macro>
               <Name>Radial Grid</Name>
               <Command>^c^c_bimgrid;_r</Command>
               <HelpString>Creates a 2D, radial grid.</HelpString>
               <Image ID="bimgrid_radial"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bimanchor">
            <Macro>
               <Name>Anchor</Name>
               <Command>^c^c_bimanchor</Command>
               <HelpString>Anchors a block to another entity and maintains a connection, even when the second entity is modified.</HelpString>
               <Image ID="bimanchor"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bimopeningcreate">
            <Macro>
               <Name>Create Opening</Name>
               <Command>^c^c_bimwindowcreate;_o</Command>
               <HelpString>Creates an opening in a solid, from a profile. The opening is a solid stored on the BIM_SUBTRACT layer.</HelpString>
               <Image ID="bimopeningcreate"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bimwindowcreate">
            <Macro>
               <Name>Create Window</Name>
               <Command>^c^c_bimwindowcreate</Command>
               <HelpString>Creates a parametric, BIM window, from a profile. (BIMWINDOWCREATE)</HelpString>
               <Image ID="bimwindowcreate"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bimwindowupdate">
            <Macro>
               <Name>Update Window</Name>
               <Command>^c^c_bimwindowupdate</Command>
               <HelpString>Updates an opening made by a window or door in a solid. (BIMWINDOWUPDATE)</HelpString>
               <Image ID="bimwindowupdate"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bimupdatethickness">
            <Macro>
               <Name>Update Thickness</Name>
               <Command>^c^c_bimupdatethickness</Command>
               <HelpString>Re-applies the overall thickness of a composition to a solid. (BIMUPDATETHICKNESS)</HelpString>
               <Image ID="bimupdatethickness"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bimclassify">
            <Macro>
               <Name>Classify</Name>
               <Command>^c^c_bimclassify</Command>
               <HelpString>Classifies an entity and gives it a name and an internal unique GUID - Globally Unique IDentifier. (BIMCLASSIFY)</HelpString>
               <Image ID="bimclassify_general"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bimclassify_element">
            <Macro>
               <Name>Classify as Building Element</Name>
               <Command>^c^c_bimclassify;_e</Command>
               <HelpString>Classifies an entity as a building element.</HelpString>
               <Image ID="bimclassify_element"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bimclassify_wall">
            <Macro>
               <Name>Classify as Wall</Name>
               <Command>^c^c_bimclassify;_w</Command>
               <HelpString>Classifies an entity as a wall.</HelpString>
               <Image ID="bimclassify_wall"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bimclassify_column">
            <Macro>
               <Name>Classify as Column</Name>
               <Command>^c^c_bimclassify;_c</Command>
               <HelpString>Classifies an entity as a column.</HelpString>
               <Image ID="bimclassify_column"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bimclassify_slab">
            <Macro>
               <Name>Classify as Slab</Name>
               <Command>^c^c_bimclassify;_s</Command>
               <HelpString>Classifies an entity as a slab.</HelpString>
               <Image ID="bimclassify_slab"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bimclassify_beam">
            <Macro>
               <Name>Classify as Beam</Name>
               <Command>^c^c_bimclassify;_b</Command>
               <HelpString>Classifies an entity as a beam.</HelpString>
               <Image ID="bimclassify_beam"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bimclassify_door">
            <Macro>
               <Name>Classify as Door</Name>
               <Command>^c^c_bimclassify;_d</Command>
               <HelpString>Classifies an entity as a door.</HelpString>
               <Image ID="bimclassify_door"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bimclassify_window">
            <Macro>
               <Name>Classify as Window</Name>
               <Command>^c^c_bimclassify;_i</Command>
               <HelpString>Classifies an entity as a window.</HelpString>
               <Image ID="bimclassify_window"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bimclassify_ramp">
            <Macro>
               <Name>Classify as Ramp</Name>
               <Command>^c^c_bimclassify;_ramp</Command>
               <HelpString>Classifies an entity as a ramp.</HelpString>
               <Image ID="bimclassify_ramp"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="bimclassify_roof">
            <Macro>
               <Name>Classify as Roof</Name>
