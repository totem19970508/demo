      <MacroGroup Name="Modify">
         <MenuMacro UID="manipulate">
            <Macro>
               <Name>Manipulate</Name>
               <Command>^c^c_manipulate</Command>
               <HelpString>Displays the Manipulator to move, rotate, copy, mirror, or scale entities with the cursor. (MANIPULATE)</HelpString>
               <Image ID="manipulate"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="move">
            <Macro>
               <Name>Move</Name>
               <Command>^c^c_move</Command>
               <HelpString>Moves entities. (MOVE)</HelpString>
               <Image ID="move"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="copy">
            <Macro>
               <Name>Copy</Name>
               <Command>^c^c_copy</Command>
               <HelpString>Copies entities. (COPY)</HelpString>
               <Image ID="copy"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="offset">
            <Macro>
               <Name>Offset</Name>
               <Command>^c^c_offset</Command>
               <HelpString>Creates a parallel copy of lines, polylines, splines and edges. (OFFSET)</HelpString>
               <Image ID="offset"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="generateboundary">
            <Macro>
               <Name>Generate Boundary</Name>
               <Command>^c^c_generateboundary</Command>
               <HelpString>Generates a boundary around a closed region or face. (GENERATEBOUNDARY)</HelpString>
               <Image ID="generateboundary"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="xedges">
            <Macro>
               <Name>Extract Edges</Name>
               <Command>^c^c_xedges</Command>
               <HelpString>Generates 2D geometry from the edges of a surface, 3D solid or region, and/or subentities. (XEDGES)</HelpString>
               <Image ID="xedges"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="xfaces">
            <Macro>
               <Name>Extract Faces</Name>
               <Command>^c^c_xfaces</Command>
               <HelpString>Creates surfaces from the faces of a surface, 3D solid or region. (XFACES)</HelpString>
               <Image ID="acis_face_copy"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="scale">
            <Macro>
               <Name>Scale</Name>
               <Command>^c^c_scale</Command>
               <HelpString>Resizes 2D and 3D entities and does not change the aspect ratio. (SCALE)</HelpString>
               <Image ID="scale"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="rotate">
            <Macro>
               <Name>2D Rotate</Name>
               <Command>^c^c_rotate</Command>
               <HelpString>Rotates entities around a point. (ROTATE)</HelpString>
               <Image ID="rotate"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="rotate3d">
            <Macro>
               <Name>3D Rotate</Name>
               <Command>^c^c_rotate3d</Command>
               <HelpString>Rotates entities around an axis. (ROTATE3D)</HelpString>
               <Image ID="rotate3d"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="mirror">
            <Macro>
               <Name>2D Mirror</Name>
               <Command>^c^c_mirror</Command>
