         </MenuMacro>
         <MenuMacro UID="setlicenselevelultimate">
            <Macro>
               <Name>Run as BricsCAD Ultimate</Name>
               <Command>^c^c_setlicenselevel;_bricscad;_ultimate;</Command>
               <HelpString>Runs BricsCAD at the BricsCAD Ultimate license level, if the license is available. A restart is required.</HelpString>
               <Image ID="license_ultimate"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="license_manager">
            <Macro>
               <Name>License Manager...</Name>
               <Command>^c^c_licensemanager</Command>
               <HelpString>Opens the Bricsys License manager dialog box, to view and manage Bricsys licenses. (LICENSEMANAGER)</HelpString>
               <Image ID="license"/>
            </Macro>
         </MenuMacro>
         <MenuMacro UID="tutorials">
            <Macro>
               <Name>Tutorials...</Name>
               <Command>^c^c_tutorialsopen;</Command>
               <HelpString>Opens the in-product tutorials. (TUTORIALSOPEN)</HelpString>
               <Image ID="tutorials"/>
            </Macro>
         </MenuMacro>
